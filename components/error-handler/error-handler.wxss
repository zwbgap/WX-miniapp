.error-overlay {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx;
}

.error-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 64rpx 48rpx;
  width: 100%;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}

.error-icon {
  margin-bottom: 24rpx;
}

.error-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #323233;
  margin-bottom: 12rpx;
  text-align: center;
}

.error-desc {
  font-size: 26rpx;
  color: #969799;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.error-actions {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}
