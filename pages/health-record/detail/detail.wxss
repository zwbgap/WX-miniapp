.detail-container {
  min-height: 100vh;
  background-color: #f6f6f6;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.page-loading {
  padding-top: 300rpx;
}

/* 浮动编辑按钮 */
.edit-fab {
  position: fixed;
  right: 40rpx;
  bottom: 200rpx;
  z-index: 99;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07c160, #06ae56);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.4);
}

/* ========== 卡片通用 ========== */
.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  margin: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 28rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.card-icon-box {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
}

/* ========== 基本信息网格 ========== */
.info-grid {
  display: flex;
  flex-wrap: wrap;
}

.info-item {
  width: 50%;
  padding: 12rpx 0;
}

.info-label {
  display: block;
  font-size: 24rpx;
  color: #969799;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 30rpx;
  color: #323233;
  font-weight: 500;
}

.info-value.highlight {
  font-weight: 700;
  color: #ee0a24;
}

.info-value-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  font-size: 30rpx;
  font-weight: 500;
}

/* ========== 身体指标 ========== */
.metrics-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  padding: 16rpx 0 32rpx;
}

.metric-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.metric-value {
  font-size: 52rpx;
  font-weight: 700;
  color: #1989fa;
  line-height: 1.1;
}

.metric-unit {
  font-size: 22rpx;
  color: #969799;
  margin-top: 4rpx;
}

.metric-label {
  font-size: 24rpx;
  color: #646566;
  margin-top: 8rpx;
  font-weight: 500;
}

.metric-divider {
  width: 2rpx;
  height: 80rpx;
  background-color: #f0f0f0;
}

/* BMI 进度条 */
.bmi-bar-section {
  padding: 0 4rpx;
}

.bmi-range-labels {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-top: 12rpx;
}

/* ========== 健康史 ========== */
.history-section {
  padding: 0;
}

.history-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 20rpx 0;
}

.history-item + .history-item {
  border-top: 1rpx solid #f5f5f5;
}

.history-tag {
  width: 120rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #ffffff;
  flex-shrink: 0;
  margin-right: 20rpx;
  margin-top: 4rpx;
}

.history-tag.danger {
  background-color: #ee0a24;
}

.history-tag.warning {
  background-color: #ff976a;
}

.history-tag.success {
  background-color: #07c160;
}

.history-content {
  flex: 1;
  font-size: 28rpx;
  color: #323233;
  line-height: 1.6;
  word-break: break-all;
}

/* ========== 更新时间 ========== */
.update-time {
  text-align: center;
  padding: 32rpx 0;
}

.bottom-safe {
  height: calc(120rpx + constant(safe-area-inset-bottom));
  height: calc(120rpx + env(safe-area-inset-bottom));
}
