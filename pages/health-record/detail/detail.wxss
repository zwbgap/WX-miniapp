.detail-container {
  min-height: 100vh;
  background-color: #f6f6f6;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.page-loading {
  padding-top: 300rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  padding: 32rpx 32rpx 16rpx;
}

/* 浮动编辑按钮 */
.edit-fab {
  position: fixed;
  right: 40rpx;
  bottom: 200rpx;
  z-index: 99;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07c160, #06ae56);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.4);
}

/* ========== 卡片通用 ========== */
.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  margin: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 28rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.card-icon-box {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.card-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #1989fa;
  margin-right: 16rpx;
}

/* ========== 身体指标卡片 ========== */
.body-index-card {
  background: linear-gradient(135deg, #f0f7ff 0%, #ffffff 100%);
  border: 1rpx solid #e6f0ff;
}

.index-item {
  padding: 16rpx 0;
}

.index-item + .index-item {
  border-top: 1rpx solid #f0f7ff;
}

.index-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.index-label {
  font-size: 28rpx;
  color: #646566;
}

.index-value-wrap {
  display: flex;
  flex-direction: row;
  align-items: baseline;
}

.index-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.index-unit {
  font-size: 24rpx;
  color: #969799;
  margin-left: 8rpx;
}

/* ========== BMI 预览 ========== */
.bmi-section {
  background: linear-gradient(135deg, #e6f9f0 0%, #ffffff 100%);
  border: 1rpx solid #ccefe0;
  border-radius: 24rpx;
  margin: 24rpx;
  padding: 32rpx;
  text-align: center;
}

.bmi-title {
  font-size: 26rpx;
  color: #969799;
  margin-bottom: 12rpx;
}

.bmi-value {
  font-size: 72rpx;
  font-weight: 700;
  color: #07c160;
  line-height: 1.1;
}

.bmi-level {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: rgba(7, 193, 96, 0.1);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #07c160;
  margin-top: 12rpx;
  margin-bottom: 12rpx;
}

.bmi-tips {
  font-size: 22rpx;
  color: #969799;
}

/* ========== 健康史 ========== */
.history-section {
  padding: 0;
}

.history-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 20rpx 0;
}

.history-item + .history-item {
  border-top: 1rpx solid #f5f5f5;
}

.history-tag {
  width: 120rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #ffffff;
  flex-shrink: 0;
  margin-right: 20rpx;
  margin-top: 4rpx;
}

.history-tag.danger {
  background-color: #ee0a24;
}

.history-tag.warning {
  background-color: #ff976a;
}

.history-tag.success {
  background-color: #07c160;
}

.history-tag.primary {
  background-color: #1989fa;
}

.history-content {
  flex: 1;
  font-size: 28rpx;
  color: #323233;
  line-height: 1.6;
  word-break: break-all;
}

/* ========== 生活方式 ========== */
.field-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.field-row + .field-row {
  border-top: 1rpx solid #f5f5f5;
}

.field-label {
  font-size: 28rpx;
  color: #646566;
}

.field-value {
  font-size: 28rpx;
  color: #323233;
  font-weight: 500;
}

/* ========== 更新时间 ========== */
.update-time {
  text-align: center;
  padding: 32rpx 0;
}

.bottom-safe {
  height: calc(120rpx + constant(safe-area-inset-bottom));
  height: calc(120rpx + env(safe-area-inset-bottom));
}

/* ========== 文字颜色 ========== */
.text-xs {
  font-size: 22rpx;
}

.text-sm {
  font-size: 24rpx;
}

.text-secondary {
  color: #969799;
}

.ml-8 {
  margin-left: 8rpx;
}