<wxs module="genderUtil">
  var getGenderText = function(val) {
    if (val == 1 || val == '1' || val === '男') return '男';
    if (val == 2 || val == '2' || val === '女') return '女';
    return val || '未设置';
  };
  var getGenderIcon = function(val) {
    if (val == 1 || val == '1' || val === '男') return 'male';
    if (val == 2 || val == '2' || val === '女') return 'female';
    return 'question-o';
  };
  var getGenderColor = function(val) {
    if (val == 1 || val == '1' || val === '男') return '#1989fa';
    if (val == 2 || val == '2' || val === '女') return '#ff4d6d';
    return '#c8c9cc';
  };
  module.exports.getGenderText = getGenderText;
  module.exports.getGenderIcon = getGenderIcon;
  module.exports.getGenderColor = getGenderColor;
</wxs>

<view class="detail-container">
  <van-loading wx:if="{{loading}}" custom-class="page-loading" />

  <block wx:elif="{{record}}">
    <view class="edit-fab" bind:tap="onEdit">
      <van-icon name="edit" size="36rpx" color="#ffffff" />
    </view>

    <view class="page-title">{{record.title || '健康档案'}}</view>

    <view class="card body-index-card">
      <view class="card-header">
        <view class="card-dot"></view>
        <text class="card-title">身体指标</text>
      </view>

      <view class="index-item">
        <view class="index-row">
          <text class="index-label">身高</text>
          <view class="index-value-wrap">
            <text class="index-value">{{record.shengao || '--'}}</text>
            <text class="index-unit">cm</text>
          </view>
        </view>
      </view>

      <view class="index-item">
        <view class="index-row">
          <text class="index-label">体重</text>
          <view class="index-value-wrap">
            <text class="index-value">{{record.tizhong || '--'}}</text>
            <text class="index-unit">kg</text>
          </view>
        </view>
      </view>
    </view>

    <view class="bmi-section" wx:if="{{bmi > 0}}">
      <view class="bmi-title">您的 BMI 指数</view>
      <view class="bmi-value">{{bmi}}</view>
      <view class="bmi-level">{{bmiLevel}}</view>
      <view class="bmi-tips">健康体重建议：BMI 18.5 - 23.9</view>
    </view>

    <view class="card">
      <view class="card-header">
        <view class="card-dot" style="background-color: #ff976a;"></view>
        <text class="card-title">健康史</text>
      </view>

      <van-field label="过敏史" value="{{record.guominshi}}" type="textarea" disabled left-icon="warning-o" />
      <van-field label="疾病史" value="{{record.jibingshi}}" type="textarea" disabled left-icon="notes-o" />
      <van-field label="健康状况" value="{{record.jiankangzhuangkuang}}" type="textarea" disabled left-icon="smile-o" />
    </view>

    <view class="card">
      <view class="card-header">
        <view class="card-dot" style="background-color: #07c160;"></view>
        <text class="card-title">生活方式</text>
      </view>

      <view class="field-row">
        <text class="field-label">吸烟习惯</text>
        <text class="field-value">{{record.xiyan || '无'}}</text>
      </view>

      <view class="field-row">
        <text class="field-label">饮酒习惯</text>
        <text class="field-value">{{record.yinjiul || '无'}}</text>
      </view>

      <view class="field-row">
        <text class="field-label">运动频率</text>
        <text class="field-value">{{record.yundong || '每周几次'}}</text>
      </view>

      <view class="field-row">
        <text class="field-label">饮食习惯</text>
        <text class="field-value">{{record.yinshi || '规律'}}</text>
      </view>
    </view>

    <view class="card">
      <view class="card-header">
        <view class="card-dot" style="background-color: #ff976a;"></view>
        <text class="card-title">用药信息</text>
      </view>

      <van-field label="用药类型" value="{{record.yongyao_leixing}}" type="textarea" disabled left-icon="medicine-box-o" />
      <van-field label="药物名称" value="{{record.yongyao_mingcheng}}" type="textarea" disabled left-icon="label-o" />
      <van-field label="药物过敏" value="{{record.yongyao_guomin}}" type="textarea" disabled left-icon="warning-o" />
    </view>

    <view class="update-time">
      <text class="text-xs" style="color:#c8c9cc;">记录日期：{{record.recordDate || '--'}}</text>
    </view>
  </block>

  <van-empty wx:else description="档案数据异常" />

  <view class="bottom-safe"></view>
</view>