.edit-container {
  min-height: 100vh;
  background-color: #f6f6f6;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.page-loading {
  padding-top: 300rpx;
}

/* ========== 卡片通用 ========== */
.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  margin: 24rpx;
  padding: 32rpx 0 0;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 0 32rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  margin-bottom: 0;
}

.card-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
}

/* ========== 性别选择行 ========== */
.field-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.field-label {
  width: 180rpx;
  font-size: 28rpx;
  color: #323233;
}

/* ========== 滑块区域 ========== */
.slider-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 8rpx 40rpx 24rpx;
}

.slider-end {
  flex-shrink: 0;
  width: 80rpx;
  text-align: center;
}

/* ========== BMI 实时预览 ========== */
.bmi-preview {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx 28rpx;
}

.bmi-preview-value {
  font-size: 44rpx;
  font-weight: 700;
  margin-right: 16rpx;
}

.bmi-preview-label {
  display: flex;
  align-items: center;
}

/* ========== 操作按钮区 ========== */
.action-bar {
  display: flex;
  flex-direction: row;
  padding: 48rpx 24rpx;
}

.action-bar van-button:first-child {
  flex: 1;
  margin-right: 24rpx;
}

.action-bar van-button:last-child {
  flex: 2;
}

.bottom-safe {
  height: calc(40rpx + constant(safe-area-inset-bottom));
  height: calc(40rpx + env(safe-area-inset-bottom));
}
