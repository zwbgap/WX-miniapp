.edit-container {
  min-height: 100vh;
  background-color: #f6f6f6;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.page-loading {
  padding-top: 300rpx;
}

/* ========== 卡片通用 ========== */
.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  margin: 24rpx;
  padding: 32rpx 0 0;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 0 32rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  margin-bottom: 0;
}

.card-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
}

/* ========== 身体指标卡片 ========== */
.body-index-card {
  background: linear-gradient(135deg, #ffffff 0%, #f0f9ff 100%);
  border: 2rpx solid #e0f2fe;
}

.body-index-card .card-header {
  border-bottom-color: #e0f2fe;
}

.body-index-card .card-dot {
  background: linear-gradient(135deg, #1989fa 0%, #06b6d4 100%);
  box-shadow: 0 4rpx 12rpx rgba(25, 137, 250, 0.3);
}

.body-index-card .card-title {
  color: #0369a1;
}

/* ========== 指标输入项 ========== */
.index-item {
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #e0f2fe;
}

.index-item:last-child {
  border-bottom: none;
}

.index-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.index-label {
  font-size: 28rpx;
  color: #374151;
  font-weight: 500;
}

.index-value-wrap {
  display: flex;
  align-items: center;
}

.index-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e40af;
  margin-right: 8rpx;
}

.index-unit {
  font-size: 24rpx;
  color: #64748b;
}

/* ========== 滑块区域 ========== */
.slider-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 32rpx 20rpx;
  background-color: rgba(25, 137, 250, 0.04);
  margin: 0 24rpx;
  border-radius: 16rpx;
}

.slider-end {
  flex-shrink: 0;
  width: 80rpx;
  text-align: center;
  font-size: 24rpx;
  color: #64748b;
}

/* ========== BMI 实时预览 ========== */
.bmi-section {
  background: linear-gradient(135deg, #1989fa 0%, #06b6d4 100%);
  margin: 24rpx;
  border-radius: 20rpx;
  padding: 32rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(25, 137, 250, 0.3);
}

.bmi-title {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
}

.bmi-value {
  font-size: 72rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  margin-bottom: 16rpx;
}

.bmi-level {
  display: inline-block;
  background-color: rgba(255, 255, 255, 0.25);
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #ffffff;
  backdrop-filter: blur(10px);
}

.bmi-tips {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 16rpx;
}

/* ========== 性别选择行 ========== */
.field-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.field-label {
  width: 180rpx;
  font-size: 28rpx;
  color: #323233;
}

/* ========== 操作按钮区 ========== */
.action-bar {
  display: flex;
  flex-direction: row;
  padding: 48rpx 24rpx;
}

.action-bar van-button:first-child {
  flex: 1;
  margin-right: 24rpx;
}

.action-bar van-button:last-child {
  flex: 2;
}

.bottom-safe {
  height: calc(40rpx + constant(safe-area-inset-bottom));
  height: calc(40rpx + env(safe-area-inset-bottom));
}
