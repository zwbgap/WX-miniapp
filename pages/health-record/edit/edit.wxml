<view class="edit-container">
  <van-loading wx:if="{{loading}}" custom-class="page-loading" />

  <block wx:else>
    <view class="card">
      <view class="card-header">
        <view class="card-dot" style="background-color: #07c160;"></view>
        <text class="card-title">基本信息</text>
      </view>

      <van-field
        label="姓名"
        value="{{form.xingming}}"
        placeholder="请输入姓名"
        left-icon="user-o"
        clearable
        required
        data-field="xingming"
        bind:change="onFieldChange"
      />

      <view class="field-row">
        <text class="field-label">性别</text>
        <van-radio-group value="{{form.xingbie}}" direction="horizontal" bind:change="onGenderChange">
          <van-radio name="男" checked-color="#1989fa" icon-size="32rpx">男</van-radio>
          <van-radio name="女" checked-color="#ff4d6d" icon-size="32rpx">女</van-radio>
        </van-radio-group>
      </view>

      <van-field
        label="年龄"
        value="{{form.nianling}}"
        type="number"
        placeholder="请输入年龄"
        left-icon="birthday-cake-o"
        clearable
        required
        data-field="nianling"
        bind:change="onFieldChange"
      />

      <van-field
        label="血型"
        value="{{form.xuexing || ''}}"
        placeholder="请选择血型"
        left-icon="medel-o"
        is-link
        readonly
        data-type="xuexing"
        bind:tap="onOpenPicker"
      />
    </view>

    <view class="card">
      <view class="card-header">
        <view class="card-dot" style="background-color: #1989fa;"></view>
        <text class="card-title">身体指标</text>
      </view>

      <van-field label="身高" value="{{form.shengao}}" type="number" placeholder="请输入身高(cm)" left-icon="ascending" clearable required data-field="shengao" bind:change="onFieldChange" />
      <view class="slider-wrap">
        <text class="slider-end text-xs text-secondary">50cm</text>
        <van-slider value="{{form.shengao || 170}}" min="50" max="250" step="1" bar-height="8rpx" active-color="#1989fa" custom-class="flex-1" bind:change="onHeightSliderChange" />
        <text class="slider-end text-xs text-secondary">250cm</text>
      </view>

      <van-field label="体重" value="{{form.tizhong}}" type="number" placeholder="请输入体重(kg)" left-icon="balance-o" clearable required data-field="tizhong" bind:change="onFieldChange" />
      <view class="slider-wrap">
        <text class="slider-end text-xs text-secondary">10kg</text>
        <van-slider value="{{form.tizhong || 65}}" min="10" max="300" step="1" bar-height="8rpx" active-color="#1989fa" custom-class="flex-1" bind:change="onWeightSliderChange" />
        <text class="slider-end text-xs text-secondary">300kg</text>
      </view>

      <view class="bmi-preview" wx:if="{{bmi > 0}}">
        <view class="bmi-preview-value" style="color: {{bmiColor}};">{{bmi}}</view>
        <view class="bmi-preview-label">
          <van-tag type="{{bmiLevel === '正常' ? 'success' : (bmiLevel === '偏瘦' || bmiLevel === '偏胖' ? 'warning' : 'danger')}}" size="medium">BMI {{bmiLevel}}</van-tag>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="card-header">
        <view class="card-dot" style="background-color: #ff976a;"></view>
        <text class="card-title">健康史</text>
      </view>

      <van-field label="过敏史" value="{{form.guominshi}}" type="textarea" placeholder="请输入过敏史，如无请填\"无\"" autosize left-icon="warning-o" data-field="guominshi" bind:change="onFieldChange" />
      <van-field label="疾病史" value="{{form.jibingshi}}" type="textarea" placeholder="请输入疾病史，如无请填\"无\"" autosize left-icon="notes-o" data-field="jibingshi" bind:change="onFieldChange" />
      <van-field label="健康状况" value="{{form.jiankangzhuangkuang}}" type="textarea" placeholder="请描述当前健康状况" autosize left-icon="smile-o" data-field="jiankangzhuangkuang" bind:change="onFieldChange" />
    </view>

    <view class="card">
      <view class="card-header">
        <view class="card-dot" style="background-color: #07c160;"></view>
        <text class="card-title">生活方式</text>
      </view>

      <view class="field-row">
        <text class="field-label">吸烟习惯</text>
        <van-radio-group value="{{form.xiyan}}" direction="horizontal" bind:change="onRadioChange" data-field="xiyan">
          <van-radio name="无" checked-color="#1989fa" icon-size="28rpx">无</van-radio>
          <van-radio name="偶尔" checked-color="#1989fa" icon-size="28rpx">偶尔</van-radio>
          <van-radio name="经常" checked-color="#1989fa" icon-size="28rpx">经常</van-radio>
          <van-radio name="已戒烟" checked-color="#1989fa" icon-size="28rpx">已戒</van-radio>
        </van-radio-group>
      </view>

      <view class="field-row">
        <text class="field-label">饮酒习惯</text>
        <van-radio-group value="{{form.yinjiul}}" direction="horizontal" bind:change="onRadioChange" data-field="yinjiul">
          <van-radio name="无" checked-color="#1989fa" icon-size="28rpx">无</van-radio>
          <van-radio name="偶尔" checked-color="#1989fa" icon-size="28rpx">偶尔</van-radio>
          <van-radio name="经常" checked-color="#1989fa" icon-size="28rpx">经常</van-radio>
          <van-radio name="已戒酒" checked-color="#1989fa" icon-size="28rpx">已戒</van-radio>
        </van-radio-group>
      </view>

      <view class="field-row">
        <text class="field-label">运动频率</text>
        <van-radio-group value="{{form.yundong}}" direction="horizontal" bind:change="onRadioChange" data-field="yundong">
          <van-radio name="每天" checked-color="#1989fa" icon-size="28rpx">每天</van-radio>
          <van-radio name="每周几次" checked-color="#1989fa" icon-size="28rpx">每周</van-radio>
          <van-radio name="偶尔" checked-color="#1989fa" icon-size="28rpx">偶尔</van-radio>
          <van-radio name="从不" checked-color="#1989fa" icon-size="28rpx">从不</van-radio>
        </van-radio-group>
      </view>

      <van-field label="睡眠时长" value="{{form.shuimian}}" type="number" placeholder="平均每日睡眠小时数" left-icon="clock-o" clearable data-field="shuimian" bind:change="onFieldChange">
        <text slot="right-icon" class="text-secondary">小时/天</text>
      </van-field>

      <view class="field-row">
        <text class="field-label">饮食习惯</text>
        <van-radio-group value="{{form.yinshi}}" direction="horizontal" bind:change="onRadioChange" data-field="yinshi">
          <van-radio name="规律" checked-color="#1989fa" icon-size="28rpx">规律</van-radio>
          <van-radio name="基本规律" checked-color="#1989fa" icon-size="28rpx">基本</van-radio>
          <van-radio name="不规律" checked-color="#1989fa" icon-size="28rpx">不规律</van-radio>
        </van-radio-group>
      </view>
    </view>

    <view class="card">
      <view class="card-header">
        <view class="card-dot" style="background-color: #ee0a24;"></view>
        <text class="card-title">家族病史</text>
      </view>

      <view class="field-row">
        <text class="field-label">高血压</text>
        <van-radio-group value="{{form.jiazu_gaoxueya}}" direction="horizontal" bind:change="onRadioChange" data-field="jiazu_gaoxueya">
          <van-radio name="有" checked-color="#ee0a24" icon-size="28rpx">有</van-radio>
          <van-radio name="无" checked-color="#07c160" icon-size="28rpx">无</van-radio>
          <van-radio name="不详" checked-color="#969799" icon-size="28rpx">不详</van-radio>
        </van-radio-group>
      </view>

      <view class="field-row">
        <text class="field-label">糖尿病</text>
        <van-radio-group value="{{form.jiazu_tangniaobing}}" direction="horizontal" bind:change="onRadioChange" data-field="jiazu_tangniaobing">
          <van-radio name="有" checked-color="#ee0a24" icon-size="28rpx">有</van-radio>
          <van-radio name="无" checked-color="#07c160" icon-size="28rpx">无</van-radio>
          <van-radio name="不详" checked-color="#969799" icon-size="28rpx">不详</van-radio>
        </van-radio-group>
      </view>

      <view class="field-row">
        <text class="field-label">心脏病</text>
        <van-radio-group value="{{form.jiazu_xinzang}}" direction="horizontal" bind:change="onRadioChange" data-field="jiazu_xinzang">
          <van-radio name="有" checked-color="#ee0a24" icon-size="28rpx">有</van-radio>
          <van-radio name="无" checked-color="#07c160" icon-size="28rpx">无</van-radio>
          <van-radio name="不详" checked-color="#969799" icon-size="28rpx">不详</van-radio>
        </van-radio-group>
      </view>

      <van-field label="其他病史" value="{{form.jiazu_qita}}" type="textarea" placeholder="请输入其他家族病史" autosize left-icon="notes-o" data-field="jiazu_qita" bind:change="onFieldChange" />
    </view>

    <view class="card">
      <view class="card-header">
        <view class="card-dot" style="background-color: #1989fa;"></view>
        <text class="card-title">应急信息</text>
      </view>

      <van-field label="紧急联系人" value="{{form.jinji_lianxiren}}" placeholder="请输入姓名" left-icon="contact-o" clearable data-field="jinji_lianxiren" bind:change="onFieldChange" />
      <van-field label="联系电话" value="{{form.jinji_dianhua}}" type="number" placeholder="请输入手机号" left-icon="phone-o" clearable data-field="jinji_dianhua" bind:change="onFieldChange" />

      <view class="field-row">
        <text class="field-label">医保类型</text>
        <van-radio-group value="{{form.jinji_yibao}}" direction="horizontal" bind:change="onRadioChange" data-field="jinji_yibao">
          <van-radio name="职工医保" checked-color="#1989fa" icon-size="28rpx">职工</van-radio>
          <van-radio name="居民医保" checked-color="#1989fa" icon-size="28rpx">居民</van-radio>
          <van-radio name="商业保险" checked-color="#1989fa" icon-size="28rpx">商业</van-radio>
          <van-radio name="自费" checked-color="#1989fa" icon-size="28rpx">自费</van-radio>
        </van-radio-group>
      </view>

      <view class="field-row">
        <text class="field-label">植入器械</text>
        <van-radio-group value="{{form.jinjicheng_duixiang}}" direction="horizontal" bind:change="onRadioChange" data-field="jinjicheng_duixiang">
          <van-radio name="无" checked-color="#07c160" icon-size="28rpx">无</van-radio>
          <van-radio name="心脏起搏器" checked-color="#ee0a24" icon-size="28rpx">起搏器</van-radio>
          <van-radio name="支架" checked-color="#ee0a24" icon-size="28rpx">支架</van-radio>
          <van-radio name="其他" checked-color="#ff976a" icon-size="28rpx">其他</van-radio>
        </van-radio-group>
      </view>
    </view>

    <view class="card">
      <view class="card-header">
        <view class="card-dot" style="background-color: #ff976a;"></view>
        <text class="card-title">用药信息</text>
      </view>

      <van-field label="用药类型" value="{{form.yongyao_leixing}}" type="textarea" placeholder="如：降压药、降糖药等" autosize left-icon="medicine-box-o" data-field="yongyao_leixing" bind:change="onFieldChange" />
      <van-field label="药物名称" value="{{form.yongyao_mingcheng}}" type="textarea" placeholder="请输入正在服用的药物名称" autosize left-icon="label-o" data-field="yongyao_mingcheng" bind:change="onFieldChange" />
      <van-field label="药物过敏" value="{{form.yongyao_guomin}}" type="textarea" placeholder="请输入药物过敏史，如无请填\"无\"" autosize left-icon="warning-o" data-field="yongyao_guomin" bind:change="onFieldChange" />
    </view>

    <view class="action-bar">
      <van-button size="large" round plain hairline type="default" bind:tap="onCancel">取消</van-button>
      <van-button size="large" round type="primary" loading="{{submitting}}" loading-text="保存中..." bind:tap="onSubmit">保存档案</van-button>
    </view>
  </block>

  <van-popup show="{{pickerVisible}}" position="bottom" round bind:close="onPickerCancel">
    <van-picker columns="{{bloodTypeColumns}}" default-index="{{pickerValue}}" show-toolbar title="选择血型" bind:confirm="onPickerConfirm" bind:cancel="onPickerCancel" />
  </van-popup>

  <view class="bottom-safe"></view>
</view>