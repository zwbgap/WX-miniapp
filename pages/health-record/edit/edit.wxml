<view class="edit-container">
  <van-loading wx:if="{{loading}}" custom-class="page-loading" />

  <block wx:else>
    <!-- 档案标题 -->
    <view class="card">
      <van-field 
        label="档案名称" 
        value="{{title}}" 
        placeholder="请输入档案名称" 
        left-icon="file-text-o"
        bind:change="onTitleChange"
      />
    </view>

    <!-- 身体指标卡片 -->
    <view class="card body-index-card">
      <view class="card-header">
        <view class="card-dot"></view>
        <text class="card-title">身体指标</text>
      </view>

      <!-- 身高 -->
      <view class="index-item">
        <view class="index-row">
          <text class="index-label">身高</text>
          <view class="index-value-wrap">
            <text class="index-value">{{form.shengao || '--'}}</text>
            <text class="index-unit">cm</text>
          </view>
        </view>
        <van-field 
          value="{{form.shengao}}" 
          type="number" 
          placeholder="请输入身高" 
          left-icon="ascending"
          data-field="shengao"
          bind:change="onFieldChange"
          custom-class="mt-8"
        />
        <view class="slider-wrap">
          <text class="slider-end">50cm</text>
          <van-slider value="{{form.shengao || 170}}" min="50" max="250" step="1" bar-height="8rpx" active-color="#1989fa" custom-class="flex-1" bind:change="onHeightSliderChange" />
          <text class="slider-end">250cm</text>
        </view>
      </view>

      <!-- 体重 -->
      <view class="index-item">
        <view class="index-row">
          <text class="index-label">体重</text>
          <view class="index-value-wrap">
            <text class="index-value">{{form.tizhong || '--'}}</text>
            <text class="index-unit">kg</text>
          </view>
        </view>
        <van-field 
          value="{{form.tizhong}}" 
          type="number" 
          placeholder="请输入体重" 
          left-icon="balance-o"
          data-field="tizhong"
          bind:change="onFieldChange"
          custom-class="mt-8"
        />
        <view class="slider-wrap">
          <text class="slider-end">10kg</text>
          <van-slider value="{{form.tizhong || 65}}" min="10" max="300" step="1" bar-height="8rpx" active-color="#1989fa" custom-class="flex-1" bind:change="onWeightSliderChange" />
          <text class="slider-end">300kg</text>
        </view>
      </view>
    </view>

    <!-- BMI 实时预览 -->
    <view class="bmi-section" wx:if="{{bmi > 0}}">
      <view class="bmi-title">您的 BMI 指数</view>
      <view class="bmi-value">{{bmi}}</view>
      <view class="bmi-level">{{bmiLevel}}</view>
      <view class="bmi-tips">健康体重建议：BMI 18.5 - 23.9</view>
    </view>

    <!-- 健康史 -->
    <view class="card">
      <view class="card-header">
        <view class="card-dot" style="background-color: #ff976a;"></view>
        <text class="card-title">健康史</text>
      </view>

      <van-field label="过敏史" value="{{form.guominshi}}" type="textarea" placeholder="请输入过敏史，如无请填\"无\"" autosize left-icon="warning-o" data-field="guominshi" bind:change="onFieldChange" />
      <van-field label="疾病史" value="{{form.jibingshi}}" type="textarea" placeholder="请输入疾病史，如无请填\"无\"" autosize left-icon="notes-o" data-field="jibingshi" bind:change="onFieldChange" />
      <van-field label="健康状况" value="{{form.jiankangzhuangkuang}}" type="textarea" placeholder="请描述当前健康状况" autosize left-icon="smile-o" data-field="jiankangzhuangkuang" bind:change="onFieldChange" />
    </view>

    <!-- 生活方式 -->
    <view class="card">
      <view class="card-header">
        <view class="card-dot" style="background-color: #07c160;"></view>
        <text class="card-title">生活方式</text>
      </view>

      <view class="field-row">
        <text class="field-label">吸烟习惯</text>
        <van-radio-group value="{{form.xiyan}}" direction="horizontal" bind:change="onRadioChange" data-field="xiyan">
          <van-radio name="无" checked-color="#1989fa" icon-size="28rpx">无</van-radio>
          <van-radio name="偶尔" checked-color="#1989fa" icon-size="28rpx">偶尔</van-radio>
          <van-radio name="经常" checked-color="#1989fa" icon-size="28rpx">经常</van-radio>
          <van-radio name="已戒烟" checked-color="#1989fa" icon-size="28rpx">已戒</van-radio>
        </van-radio-group>
      </view>

      <view class="field-row">
        <text class="field-label">饮酒习惯</text>
        <van-radio-group value="{{form.yinjiul}}" direction="horizontal" bind:change="onRadioChange" data-field="yinjiul">
          <van-radio name="无" checked-color="#1989fa" icon-size="28rpx">无</van-radio>
          <van-radio name="偶尔" checked-color="#1989fa" icon-size="28rpx">偶尔</van-radio>
          <van-radio name="经常" checked-color="#1989fa" icon-size="28rpx">经常</van-radio>
          <van-radio name="已戒酒" checked-color="#1989fa" icon-size="28rpx">已戒</van-radio>
        </van-radio-group>
      </view>

      <view class="field-row">
        <text class="field-label">运动频率</text>
        <van-radio-group value="{{form.yundong}}" direction="horizontal" bind:change="onRadioChange" data-field="yundong">
          <van-radio name="每天" checked-color="#1989fa" icon-size="28rpx">每天</van-radio>
          <van-radio name="每周几次" checked-color="#1989fa" icon-size="28rpx">每周</van-radio>
          <van-radio name="偶尔" checked-color="#1989fa" icon-size="28rpx">偶尔</van-radio>
          <van-radio name="从不" checked-color="#1989fa" icon-size="28rpx">从不</van-radio>
        </van-radio-group>
      </view>

      <view class="field-row">
        <text class="field-label">饮食习惯</text>
        <van-radio-group value="{{form.yinshi}}" direction="horizontal" bind:change="onRadioChange" data-field="yinshi">
          <van-radio name="规律" checked-color="#1989fa" icon-size="28rpx">规律</van-radio>
          <van-radio name="基本规律" checked-color="#1989fa" icon-size="28rpx">基本</van-radio>
          <van-radio name="不规律" checked-color="#1989fa" icon-size="28rpx">不规律</van-radio>
        </van-radio-group>
      </view>
    </view>

    <!-- 用药信息 -->
    <view class="card">
      <view class="card-header">
        <view class="card-dot" style="background-color: #ff976a;"></view>
        <text class="card-title">用药信息</text>
      </view>

      <van-field label="用药类型" value="{{form.yongyao_leixing}}" type="textarea" placeholder="如：降压药、降糖药等" autosize left-icon="medicine-box-o" data-field="yongyao_leixing" bind:change="onFieldChange" />
      <van-field label="药物名称" value="{{form.yongyao_mingcheng}}" type="textarea" placeholder="请输入正在服用的药物名称" autosize left-icon="label-o" data-field="yongyao_mingcheng" bind:change="onFieldChange" />
      <van-field label="药物过敏" value="{{form.yongyao_guomin}}" type="textarea" placeholder="请输入药物过敏史，如无请填\"无\"" autosize left-icon="warning-o" data-field="yongyao_guomin" bind:change="onFieldChange" />
    </view>

    <view class="action-bar">
      <van-button size="large" round plain hairline type="default" bind:tap="onCancel">取消</van-button>
      <van-button size="large" round type="primary" loading="{{submitting}}" loading-text="保存中..." bind:tap="onSubmit">保存档案</van-button>
    </view>
  </block>

  <view class="bottom-safe"></view>


</view>
