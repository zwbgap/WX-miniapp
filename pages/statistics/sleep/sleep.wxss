.container { min-height: 100vh; background-color: #f6f6f6; }
.overview-row {
  display: flex; flex-direction: row;
  margin: 24rpx; background: #fff; border-radius: 24rpx;
  padding: 32rpx 0;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}
.overview-item { flex: 1; display: flex; flex-direction: column; align-items: center; }
.overview-item+.overview-item { border-left: 1rpx solid #f0f0f0; }
.overview-value { font-size: 40rpx; font-weight: 700; color: #1989fa; }
.overview-label { font-size: 22rpx; color: #969799; margin-top: 8rpx; }

.page-loading { padding-top: 200rpx; }

.card { background: #fff; border-radius: 24rpx; margin: 24rpx; padding: 28rpx; box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04); }
.card-header { display: flex; flex-direction: row; align-items: center; padding-bottom: 16rpx; border-bottom: 1rpx solid #f5f5f5; margin-bottom: 8rpx; }
.card-title { font-size: 28rpx; font-weight: 700; color: #1a1a1a; }

.bottom-safe { height: calc(40rpx + constant(safe-area-inset-bottom)); height: calc(40rpx + env(safe-area-inset-bottom)); }
