.stats-container {
  min-height: 100vh;
  background-color: #f6f6f6;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.page-loading { padding-top: 300rpx; }

.score-hero {
  position: relative;
  margin: 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.score-hero-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, #07c160, #1989fa);
  z-index: 0;
}

.score-hero-content {
  position: relative; z-index: 1;
  display: flex; flex-direction: row; align-items: center;
  padding: 36rpx 32rpx;
}

.score-circle {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background-color: rgba(255,255,255,0.2);
  display: flex; align-items: center; justify-content: center;
  margin-right: 24rpx;
}

.score-inner {
  display: flex; flex-direction: column; align-items: center;
}

.score-num { font-size: 44rpx; font-weight: 700; color: #fff; line-height: 1; }
.score-unit { font-size: 20rpx; color: rgba(255,255,255,0.7); margin-top: 2rpx; }

.score-info { flex: 1; }
.score-title { font-size: 32rpx; font-weight: 700; color: #fff; margin-bottom: 8rpx; }
.score-desc { font-size: 24rpx; color: rgba(255,255,255,0.7); }

.score-stats {
  position: relative; z-index: 1;
  display: flex; flex-direction: row;
  border-top: 1rpx solid rgba(255,255,255,0.15);
  padding: 20rpx 16rpx;
}

.score-stat-item {
  flex: 1; display: flex; flex-direction: column; align-items: center;
}
.score-stat-value { font-size: 28rpx; font-weight: 600; color: #fff; }
.score-stat-label { font-size: 20rpx; color: rgba(255,255,255,0.6); margin-top: 4rpx; }

.card {
  background-color: #fff; border-radius: 24rpx;
  margin: 24rpx; padding: 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}

.card-header {
  display: flex; flex-direction: row; align-items: center;
  padding-bottom: 16rpx; margin-bottom: 4rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.mini-header { margin-bottom: 0; padding-bottom: 12rpx; }

.card-dot { width: 12rpx; height: 12rpx; border-radius: 50%; margin-right: 12rpx; }
.card-title { font-size: 28rpx; font-weight: 700; color: #1a1a1a; flex: 1; }
.card-more { font-size: 24rpx; color: #1989fa; }

.card-row {
  display: flex; flex-direction: row; margin: 0;
}

.card-half {
  flex: 1; margin: 0 12rpx 24rpx; min-width: 0;
}

.card-half:first-child { margin-left: 24rpx; }
.card-half:last-child { margin-right: 24rpx; }

.chart-wrap {
  display: flex; flex-direction: row; margin-top: 20rpx;
}

.chart-y-axis {
  width: 60rpx; display: flex; flex-direction: column;
  justify-content: space-between; align-items: flex-end;
  padding-bottom: 40rpx;
}

.chart-y-axis text {
  font-size: 18rpx; color: #c8c9cc;
}

.chart-content {
  flex: 1; margin-left: 12rpx;
}

.chart-bars-row {
  display: flex; flex-direction: row;
  align-items: flex-end; justify-content: space-around;
  height: 180rpx; padding-bottom: 8rpx;
}

.chart-bar-sleep {
  width: 48rpx; background: linear-gradient(180deg, #1989fa, #07c160);
  border-radius: 8rpx 8rpx 0 0; position: relative;
  min-height: 8rpx;
}

.bar-value {
  position: absolute; top: -36rpx; left: 50%; transform: translateX(-50%);
  font-size: 18rpx; color: #323233; white-space: nowrap;
}

.chart-line-row {
  position: relative; height: 180rpx;
  display: flex; align-items: center; padding: 0 20rpx;
}

.chart-dot-wrap {
  position: absolute; transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center;
}

.chart-dot {
  width: 16rpx; height: 16rpx; border-radius: 50%;
  background-color: #07c160; border: 4rpx solid #fff;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.4);
}

.chart-dot-value {
  font-size: 16rpx; color: #323233; margin-top: 4rpx;
  white-space: nowrap;
}

.chart-line {
  height: 4rpx; background: linear-gradient(90deg, #07c160, #69d48b);
  border-radius: 2rpx; position: absolute; left: 10%;
}

.chart-x-labels {
  display: flex; flex-direction: row;
  justify-content: space-around; margin-top: 12rpx;
}

.chart-x-labels text {
  font-size: 18rpx; color: #969799;
}

.chart-empty {
  display: flex; align-items: center; justify-content: center;
  height: 160rpx; color: #c8c9cc; font-size: 24rpx;
}

.radar-wrap {
  margin-top: 16rpx;
}

.radar-item {
  display: flex; flex-direction: row; align-items: center;
  margin-bottom: 16rpx;
}

.radar-item:last-child { margin-bottom: 0; }

.radar-label {
  width: 60rpx; font-size: 22rpx; color: #323233;
}

.radar-bar-wrap {
  flex: 1; height: 16rpx; background-color: #f0f0f0;
  border-radius: 8rpx; overflow: hidden; margin: 0 12rpx;
}

.radar-bar {
  height: 100%; border-radius: 8rpx;
  transition: width 0.5s ease;
}

.radar-value {
  width: 70rpx; font-size: 20rpx; color: #969799;
  text-align: right;
}

.pie-wrap {
  display: flex; flex-direction: column; align-items: center;
  margin-top: 16rpx;
}

.pie-chart {
  margin-bottom: 24rpx;
}

.pie-ring {
  width: 160rpx; height: 160rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  mask: radial-gradient(transparent 55rpx, #000 57rpx);
  -webkit-mask: radial-gradient(transparent 55rpx, #000 57rpx);
}

.pie-inner {
  display: flex; flex-direction: column; align-items: center;
}

.pie-value {
  font-size: 32rpx; font-weight: 700; color: #07c160;
}

.pie-label {
  font-size: 18rpx; color: #969799;
}

.pie-legend {
  width: 100%;
}

.legend-item {
  display: flex; flex-direction: row; align-items: center;
  margin-bottom: 8rpx; font-size: 20rpx; color: #646566;
}

.legend-item:last-child { margin-bottom: 0; }

.legend-dot {
  width: 12rpx; height: 12rpx; border-radius: 50%;
  margin-right: 8rpx;
}

.bottom-safe {
  height: calc(40rpx + constant(safe-area-inset-bottom));
  height: calc(40rpx + env(safe-area-inset-bottom));
}