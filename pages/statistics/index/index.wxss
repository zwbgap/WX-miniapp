.stats-container {
  min-height: 100vh;
  background-color: #f6f6f6;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.page-loading {
  padding-top: 300rpx;
}

.page-header {
  padding: 32rpx 32rpx 16rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.header-desc {
  font-size: 26rpx;
  color: #969799;
  margin-top: 8rpx;
}

.score-hero {
  position: relative;
  margin: 24rpx;
  padding: 40rpx 32rpx 32rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ae56 50%, #05a050 100%);
  border-radius: 32rpx;
  overflow: hidden;
}

.score-hero-bg {
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.score-hero-content {
  display: flex;
  flex-direction: row;
  align-items: center;
  position: relative;
  z-index: 1;
}

.score-circle {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.score-inner {
  display: flex;
  flex-direction: row;
  align-items: baseline;
}

.score-num {
  font-size: 56rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1;
}

.score-unit {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 4rpx;
}

.score-info {
  margin-left: 32rpx;
}

.score-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.score-level {
  display: inline-block;
  margin-top: 8rpx;
  padding: 6rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #ffffff;
}

.score-level.level-good {
  background: rgba(255, 255, 255, 0.25);
}

.score-level.level-warning {
  background: rgba(255, 77, 77, 0.4);
}

.score-stats {
  display: flex;
  flex-direction: row;
  justify-content: center;
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
  position: relative;
  z-index: 1;
}

.score-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.score-stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
}

.score-stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  margin: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.card-header.mini-header {
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
}

.card-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #1989fa;
  margin-right: 16rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  flex: 1;
}

.card-more {
  font-size: 24rpx;
  color: #969799;
}

.card-row {
  display: flex;
  flex-direction: row;
}

.card-half {
  flex: 1;
  margin: 24rpx 12rpx;
}

.card-half:first-child {
  margin-left: 24rpx;
}

.card-half:last-child {
  margin-right: 24rpx;
}

.body-metrics {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.metric-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.metric-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.metric-info {
  display: flex;
  flex-direction: row;
  align-items: baseline;
}

.metric-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.metric-unit {
  font-size: 22rpx;
  color: #969799;
  margin-left: 4rpx;
}

.metric-label {
  font-size: 24rpx;
  color: #646566;
  margin-top: 8rpx;
}

.metric-label.level-thin { color: #ff976a; }
.metric-label.level-normal { color: #07c160; }
.metric-label.level-overweight { color: #ff976a; }
.metric-label.level-obese { color: #ee0a24; }

.metric-divider {
  width: 2rpx;
  height: 100rpx;
  background-color: #f0f0f0;
}

.lifestyle-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.lifestyle-item {
  width: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.lifestyle-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.lifestyle-label {
  font-size: 24rpx;
  color: #969799;
}

.lifestyle-value {
  font-size: 26rpx;
  color: #323233;
  font-weight: 500;
  margin-top: 4rpx;
}

.lifestyle-value.value-good {
  color: #07c160;
}

.lifestyle-value.value-warning {
  color: #ff976a;
}

.alerts-list {
  display: flex;
  flex-direction: column;
}

.alert-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.alert-item:last-child {
  border-bottom: none;
}

.alert-text {
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #323233;
}

.medication-info {
  display: flex;
  flex-direction: column;
}

.med-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.med-item:last-child {
  border-bottom: none;
}

.med-label {
  font-size: 24rpx;
  color: #969799;
}

.med-value {
  font-size: 24rpx;
  color: #323233;
  font-weight: 500;
  max-width: 60%;
  text-align: right;
}

.empty-card {
  padding: 48rpx 32rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #646566;
  margin-top: 16rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #969799;
  margin-top: 8rpx;
}

.mt-16 {
  margin-top: 16rpx;
}

.text-danger {
  color: #ee0a24 !important;
}

.text-warning {
  color: #ff976a !important;
}

.sleep-overview {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  padding: 16rpx 0 32rpx;
}

.sleep-avg {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.sleep-avg-label {
  font-size: 24rpx;
  color: #969799;
  margin-bottom: 8rpx;
}

.sleep-avg-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #1989fa;
}

.sleep-avg-unit {
  font-size: 22rpx;
  color: #969799;
  margin-top: 4rpx;
}

.chart-wrap {
  display: flex;
  flex-direction: row;
  padding: 0 8rpx;
}

.chart-y-axis {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding-right: 12rpx;
  padding-bottom: 40rpx;
}

.chart-y-axis text {
  font-size: 20rpx;
  color: #c8c9cc;
  line-height: 1;
}

.chart-content {
  flex: 1;
}

.chart-bars-row {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  align-items: flex-end;
  height: 180rpx;
  padding: 0 8rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.chart-bar {
  width: 52rpx;
  border-radius: 8rpx 8rpx 0 0;
  background: linear-gradient(180deg, #1989fa 0%, #66b1ff 100%);
  position: relative;
  transition: height 0.3s ease;
}

.bar-value {
  position: absolute;
  top: -32rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 20rpx;
  color: #1989fa;
  font-weight: 500;
  white-space: nowrap;
}

.chart-x-labels {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  padding: 12rpx 8rpx 0;
}

.chart-x-labels text {
  font-size: 20rpx;
  color: #c8c9cc;
  width: 52rpx;
  text-align: center;
}

.sleep-tips {
  text-align: center;
  padding: 24rpx 0 0;
}

.bottom-safe {
  height: calc(120rpx + constant(safe-area-inset-bottom));
  height: calc(120rpx + env(safe-area-inset-bottom));
}