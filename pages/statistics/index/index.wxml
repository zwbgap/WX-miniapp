<view class="stats-container">
  <van-loading wx:if="{{loading}}" custom-class="page-loading" />

  <block wx:else>
    <view class="score-hero">
      <view class="score-hero-bg"></view>
      <view class="score-hero-content">
        <view class="score-circle">
          <view class="score-inner">
            <text class="score-num">{{healthScore}}</text>
            <text class="score-unit">分</text>
          </view>
        </view>
        <view class="score-info">
          <view class="score-title">综合健康评分</view>
          <view class="score-desc">持续改善中，请继续保持</view>
        </view>
      </view>
      <view class="score-stats">
        <view class="score-stat-item">
          <text class="score-stat-value">{{overviewStats.avgSleep}}</text>
          <text class="score-stat-label">均睡眠</text>
        </view>
        <view class="score-stat-item">
          <text class="score-stat-value">{{overviewStats.avgWeight}}</text>
          <text class="score-stat-label">均体重</text>
        </view>
        <view class="score-stat-item">
          <text class="score-stat-value">{{overviewStats.medicationRate}}</text>
          <text class="score-stat-label">依从性</text>
        </view>
        <view class="score-stat-item">
          <text class="score-stat-value">{{overviewStats.recordCount}}</text>
          <text class="score-stat-label">记录</text>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="card-header">
        <view class="card-dot" style="background-color:#1989fa;"></view>
        <text class="card-title">睡眠趋势（近7天）</text>
        <text class="card-more" bind:tap="onNavSleep">详情</text>
      </view>
      <view class="chart-wrap">
        <view class="chart-y-axis">
          <text>{{sleepMaxHours}}h</text>
          <text>{{sleepMaxHours / 2}}h</text>
          <text>0h</text>
        </view>
        <view class="chart-content">
          <view class="chart-bars-row">
            <view
              class="chart-bar-sleep"
              wx:for="{{sleepTrend}}"
              wx:key="date"
              style="height: {{item.hours / sleepMaxHours * 160}}rpx;"
            >
              <view class="bar-value">{{item.hours}}h</view>
            </view>
          </view>
          <view class="chart-x-labels">
            <text wx:for="{{sleepTrend}}" wx:key="date">{{item.date}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="card-header">
        <view class="card-dot" style="background-color:#07c160;"></view>
        <text class="card-title">体重变化（近10次）</text>
        <text class="card-more" bind:tap="onNavWeight">详情</text>
      </view>
      <view class="chart-wrap" wx:if="{{weightTrend.length > 0}}">
        <view class="chart-y-axis">
          <text>{{weightMaxKg}}kg</text>
          <text>{{weightMaxKg / 2}}kg</text>
          <text>0kg</text>
        </view>
        <view class="chart-content">
          <view class="chart-line-row">
            <view
              class="chart-dot-wrap"
              wx:for="{{weightTrend}}"
              wx:key="date"
              style="left: {{index / (weightTrend.length - 1) * 80}}%;"
            >
              <view class="chart-dot"></view>
              <view class="chart-dot-value">{{item.weight}}kg</view>
            </view>
            <view class="chart-line" style="width: 80%;"></view>
          </view>
          <view class="chart-x-labels">
            <text wx:for="{{weightTrend}}" wx:key="date">{{item.date}}</text>
          </view>
        </view>
      </view>
      <view class="chart-empty" wx:else>
        <text>暂无体重数据</text>
      </view>
    </view>

    <view class="card-row">
      <view class="card card-half">
        <view class="card-header mini-header">
          <view class="card-dot" style="background-color:#07c160;"></view>
          <text class="card-title">健康雷达</text>
        </view>
        <view class="radar-wrap">
          <view class="radar-item">
            <view class="radar-label">睡眠</view>
            <view class="radar-bar-wrap">
              <view class="radar-bar" style="width: {{radarData.sleep}}%; background: #1989fa;"></view>
            </view>
            <view class="radar-value">{{radarData.sleep}}%</view>
          </view>
          <view class="radar-item">
            <view class="radar-label">运动</view>
            <view class="radar-bar-wrap">
              <view class="radar-bar" style="width: {{radarData.exercise}}%; background: #07c160;"></view>
            </view>
            <view class="radar-value">{{radarData.exercise}}%</view>
          </view>
          <view class="radar-item">
            <view class="radar-label">营养</view>
            <view class="radar-bar-wrap">
              <view class="radar-bar" style="width: {{radarData.nutrition}}%; background: #ff976a;"></view>
            </view>
            <view class="radar-value">{{radarData.nutrition}}%</view>
          </view>
          <view class="radar-item">
            <view class="radar-label">用药</view>
            <view class="radar-bar-wrap">
              <view class="radar-bar" style="width: {{radarData.medication}}%; background: #ee0a24;"></view>
            </view>
            <view class="radar-value">{{radarData.medication}}%</view>
          </view>
          <view class="radar-item">
            <view class="radar-label">心情</view>
            <view class="radar-bar-wrap">
              <view class="radar-bar" style="width: {{radarData.mood}}%; background: #969799;"></view>
            </view>
            <view class="radar-value">{{radarData.mood}}%</view>
          </view>
        </view>
      </view>

      <view class="card card-half">
        <view class="card-header mini-header">
          <view class="card-dot" style="background-color:#ff976a;"></view>
          <text class="card-title">用药依从</text>
        </view>
        <view class="pie-wrap">
          <view class="pie-chart">
            <view
              class="pie-ring"
              style="background: conic-gradient(#07c160 {{adherenceData.taken / (adherenceData.total || 1) * 360}}deg, #f0f0f0 0deg);"
            >
              <view class="pie-inner">
                <text class="pie-value">{{adherenceData.taken}}</text>
                <text class="pie-label">已服用</text>
              </view>
            </view>
          </view>
          <view class="pie-legend">
            <view class="legend-item">
              <view class="legend-dot" style="background-color: #07c160;"></view>
              <text>已服用 {{adherenceData.taken}} 次</text>
            </view>
            <view class="legend-item">
              <view class="legend-dot" style="background-color: #f0f0f0;"></view>
              <text>漏服 {{adherenceData.missed}} 次</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </block>

  <view class="bottom-safe"></view>
</view>