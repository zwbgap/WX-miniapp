.detail-container {
  min-height: 100vh;
  background-color: #f6f6f6;
  padding-bottom: env(safe-area-inset-bottom);
}

.page-loading {
  padding-top: 300rpx;
}

.detail-header {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  padding: 60rpx 32rpx 40rpx;
}

.back-btn {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 12rpx;
  display: inline-block;
  margin-bottom: 24rpx;
}

.detail-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
}

.info-card {
  background: #ffffff;
  border-radius: 20rpx;
  margin: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.info-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #969799;
}

.info-value {
  font-size: 26rpx;
  color: #323233;
  font-weight: 500;
  max-width: 60%;
  text-align: right;
}

.content-card {
  background: #ffffff;
  border-radius: 20rpx;
  margin: 0 24rpx 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.content-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.content-body text {
  font-size: 28rpx;
  color: #323233;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}