.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f0f4f3;
}

.chat-body {
  flex: 1;
  overflow: hidden;
}

.chat-scroll {
  height: 100%;
  padding: 20rpx 24rpx;
}

.msg-wrap {
  margin-bottom: 24rpx;
}

.msg-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

.msg-left {
  justify-content: flex-start;
}

.msg-right {
  justify-content: flex-end;
}

.msg-avatar {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  margin: 0 12rpx;
}

.robot-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07c160, #69d48b);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
  animation: robot-bounce 2s ease-in-out infinite;
}

@keyframes robot-bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-4rpx); }
}

.user-avatar-small {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: #e8e8e8;
}

.msg-bubble {
  max-width: 480rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  position: relative;
}

.bubble-ai {
  background-color: #ffffff;
  border-top-left-radius: 6rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.bubble-user {
  background: linear-gradient(135deg, #07c160, #06ad56);
  border-top-right-radius: 6rpx;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.25);
}

.bubble-user .msg-text {
  color: #ffffff;
  font-size: 30rpx;
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-all;
}

.bubble-ai .msg-text {
  color: #323233;
  font-size: 30rpx;
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-all;
}

.bubble-user .msg-time {
  color: rgba(255, 255, 255, 0.7);
}

.bubble-ai .msg-time {
  color: #c8c9cc;
}

.msg-time {
  font-size: 20rpx;
  margin-top: 8rpx;
  text-align: right;
}

.typing-bubble {
  padding: 16rpx 32rpx;
}

.typing-dots {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #c8c9cc;
  animation: dot-blink 1.4s ease-in-out infinite;
}

.dot:nth-child(1) { animation-delay: 0s; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes dot-blink {
  0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
  40% { opacity: 1; transform: scale(1); }
}

.chat-spacer {
  height: 40rpx;
}

.chat-footer {
  background-color: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.chat-input-bar {
  padding: 16rpx 20rpx;
}

.chat-input-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #f7f8fa;
  border-radius: 40rpx;
  padding: 8rpx 12rpx 8rpx 28rpx;
}

.chat-input {
  flex: 1;
  font-size: 28rpx;
  color: #323233;
  height: 68rpx;
  line-height: 68rpx;
}

.input-placeholder {
  color: #c8c9cc;
  font-size: 28rpx;
}

.chat-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 4rpx;
}

.action-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.send-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: #d8d8d8;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.send-active {
  background: linear-gradient(135deg, #07c160, #06ad56);
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.4);
}

.chat-disclaimer {
  text-align: center;
  padding: 8rpx 0 4rpx;
  font-size: 20rpx;
  color: #c8c9cc;
}
