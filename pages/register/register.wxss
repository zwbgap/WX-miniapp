.register-container {
  min-height: 100vh;
  background-color: #ffffff;
  padding: 0 48rpx;
  box-sizing: border-box;
}

.register-header {
  padding-top: 48rpx;
  padding-bottom: 32rpx;
}

.register-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.register-subtitle {
  font-size: 26rpx;
  color: #969799;
}

.identity-selector {
  padding: 16rpx 0 32rpx;
}

.selector-title {
  font-size: 26rpx;
  color: #969799;
  text-align: center;
  margin-bottom: 24rpx;
}

.identity-options {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 80rpx;
}

.identity-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 48rpx;
  border-radius: 16rpx;
  background-color: #f5f5f5;
  transition: all 0.3s;
  min-width: 160rpx;
}

.identity-option.active {
  background-color: #07c160;
}

.identity-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 12rpx;
  background-color: rgba(255, 255, 255, 0.8);
}

.identity-option.active .identity-icon {
  background-color: rgba(255, 255, 255, 0.95);
}

.identity-label {
  font-size: 28rpx;
  color: #646566;
}

.identity-option.active .identity-label {
  color: #ffffff;
  font-weight: 600;
}

.register-btn-area {
  margin-top: 56rpx;
}

.register-footer {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
  margin-top: 40rpx;
  padding-bottom: 40rpx;
}

.register-link {
  color: #07c160;
  margin-left: 8rpx;
}