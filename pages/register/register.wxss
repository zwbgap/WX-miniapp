.register-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
  padding: 0 40rpx;
  box-sizing: border-box;
}

.register-header {
  padding-top: 80rpx;
  padding-bottom: 40rpx;
}

.register-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.register-subtitle {
  font-size: 28rpx;
  color: #969799;
  font-weight: 400;
}

.identity-selector {
  padding: 24rpx 0 32rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.selector-title {
  font-size: 28rpx;
  color: #646566;
  text-align: center;
  margin-bottom: 28rpx;
  font-weight: 500;
}

.identity-options {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 48rpx;
}

.identity-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 48rpx;
  border-radius: 20rpx;
  background-color: #f7f8fa;
  transition: all 0.3s;
  min-width: 160rpx;
  border: 2rpx solid transparent;
}

.identity-option.active {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-color: #07c160;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.25);
}

.identity-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  margin-bottom: 14rpx;
  background-color: rgba(255, 255, 255, 0.9);
}

.identity-option.active .identity-icon {
  background-color: rgba(255, 255, 255, 0.98);
}

.identity-label {
  font-size: 28rpx;
  color: #646566;
  font-weight: 500;
}

.identity-option.active .identity-label {
  color: #ffffff;
  font-weight: 600;
}

/* 注册表单卡片 */
.register-form-card {
  margin-top: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.register-btn-area {
  margin-top: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.register-footer {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
  margin-top: 40rpx;
  padding-bottom: 40rpx;
}

.register-link {
  color: #07c160;
  margin-left: 8rpx;
}

/* 自定义密码输入框包裹层 */
.password-input-wrapper {
  position: relative;
}

.password-input-wrapper .van-field {
  padding-right: 80rpx;
}

.custom-eye-icon {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 40rpx;
  z-index: 10;
  padding: 8rpx;
  cursor: pointer;
}