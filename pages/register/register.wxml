<view class="register-container">
  <view class="register-header">
    <view class="register-title">创建账号</view>
    <view class="register-subtitle">注册后可使用全部健康管理功能</view>
  </view>

  <!-- 身份选择 -->
  <view class="identity-selector">
    <view class="selector-title">选择身份</view>
    <view class="identity-options">
      <view
        class="identity-option {{identity === 'user' ? 'active' : ''}}"
        bind:tap="onSelectIdentity"
        data-identity="user"
      >
        <view class="identity-icon user-icon">👤</view>
        <text class="identity-label">用户</text>
      </view>
      <view
        class="identity-option {{identity === 'doctor' ? 'active' : ''}}"
        bind:tap="onSelectIdentity"
        data-identity="doctor"
      >
        <view class="identity-icon doctor-icon">👨‍⚕️</view>
        <text class="identity-label">医生</text>
      </view>
    </view>
  </view>

  <view class="register-form-card">
    <van-cell-group>
      <van-field
        value="{{account}}"
        placeholder="请输入账号（3-20位）"
        left-icon="user-o"
        clearable
        bind:input="onAccountInput"
      />

      <view class="password-input-wrapper">
        <van-field
          value="{{password}}"
          type="{{passwordVisible ? 'text' : 'password'}}"
          placeholder="请设置密码（6-20位）"
          left-icon="lock"
          bind:input="onPasswordInput"
        />
        <view class="custom-eye-icon" bind:tap="onTogglePasswordVisible">
          <text wx:if="{{passwordVisible}}">👁️</text>
          <text wx:else>🙈</text>
        </view>
      </view>

      <view class="password-input-wrapper">
        <van-field
          value="{{confirmPassword}}"
          type="{{confirmPasswordVisible ? 'text' : 'password'}}"
          placeholder="请再次输入密码"
          left-icon="lock"
          bind:input="onConfirmPasswordInput"
        />
        <view class="custom-eye-icon" bind:tap="onToggleConfirmPasswordVisible">
          <text wx:if="{{confirmPasswordVisible}}">👁️</text>
          <text wx:else>🙈</text>
        </view>
      </view>

      <van-field
        wx:if="{{identity === 'doctor'}}"
        value="{{inviteCode}}"
        placeholder="请输入管理员提供的邀请码"
        left-icon="coupon-o"
        clearable
        bind:input="onInviteCodeInput"
      />
    </van-cell-group>
  </view>

  <view class="register-btn-area">
    <van-button
      type="primary"
      size="large"
      round
      block
      loading="{{submitLoading}}"
      loading-text="注册中..."
      bind:tap="onSubmit"
    >
      {{identity === 'doctor' ? '医生注册' : '用户注册'}}
    </van-button>
  </view>

  <view class="register-footer">
    <text class="text-sm text-secondary">已有账号？</text>
    <text class="text-sm register-link" bind:tap="onGoLogin">立即登录</text>
  </view>
</view>