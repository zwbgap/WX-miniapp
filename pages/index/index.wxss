.page-container {
  min-height: 100vh;
  background-color: #f6f6f6;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== 顶部用户信息区 ========== */
.user-header {
  position: relative;
  margin: 24rpx 24rpx 0;
  border-radius: 24rpx;
  overflow: hidden;
}

.user-header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #07c160 0%, #1989fa 100%);
  z-index: 0;
}

.user-header-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 32rpx;
}

.user-info-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex: 1;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  background-color: #e8e8e8;
}

.user-text {
  margin-left: 24rpx;
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.2;
}

.user-greeting {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 6rpx;
}

.health-score-box {
  margin-left: 16rpx;
  flex-shrink: 0;
}

.score-ring {
  position: relative;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.score-ring-progress {
  position: absolute;
  top: 0;
  left: 0;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  mask: radial-gradient(transparent 38rpx, #000 40rpx);
  -webkit-mask: radial-gradient(transparent 38rpx, #000 40rpx);
}

.score-ring-inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.95);
}

.score-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #07c160;
  line-height: 1;
}

.score-label {
  font-size: 18rpx;
  color: #999;
  margin-top: 2rpx;
}

.user-header-tags {
  position: relative;
  z-index: 1;
  padding: 0 32rpx 28rpx;
}

.score-level-tag {
  display: inline-block;
  padding: 4rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #ffffff;
}

.user-header-guest .user-header-content {
  padding: 40rpx 32rpx;
}

/* ========== 功能入口网格 ========== */
.section {
  margin: 24rpx;
}

.quick-entry-section {
  margin-top: -16rpx;
  position: relative;
  z-index: 2;
}

.quick-entry-grid {
  display: flex;
  flex-wrap: wrap;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx 0;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.quick-entry-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
}

.entry-icon-box {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
}

.entry-name {
  font-size: 22rpx;
  color: #323233;
  text-align: center;
}

/* ========== 区块标题 ========== */
.section-header {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 4rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.section-subtitle {
  font-size: 24rpx;
  color: #969799;
}

/* ========== 今日提醒 ========== */
.reminders-section {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 28rpx 16rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.reminders-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
}

.reminder-group {
  margin-bottom: 20rpx;
}

.reminder-group:last-child {
  margin-bottom: 8rpx;
}

.reminder-group-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0 16rpx;
}

.reminder-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.reminder-group-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #323233;
  margin-right: 12rpx;
}

.reminder-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 0;
  border-top: 1rpx solid #f5f5f5;
}

.reminder-name {
  flex: 1;
  font-size: 26rpx;
  color: #323233;
  margin-left: 16rpx;
}

.reminder-time {
  font-size: 24rpx;
  color: #969799;
  margin-right: 12rpx;
}

/* ========== 睡眠趋势图表 ========== */
.sleep-chart-section {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.chart-container {
  padding: 16rpx 0;
}

.chart-bars {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: space-around;
  height: 280rpx;
  padding: 20rpx 0 0;
}

.chart-bar-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  height: 100%;
  min-width: 0;
}

.chart-bar-value {
  font-size: 20rpx;
  color: #969799;
  margin-bottom: 8rpx;
  text-align: center;
}

.chart-bar {
  width: 36rpx;
  min-height: 8rpx;
  border-radius: 8rpx 8rpx 0 0;
  transition: height 0.6s ease-out;
}

.chart-bar-label {
  font-size: 20rpx;
  color: #969799;
  margin-top: 12rpx;
  text-align: center;
}

.chart-legend {
  padding: 16rpx 0 8rpx;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

/* ========== 推荐资讯轮播 ========== */
.news-section {
  margin-bottom: 32rpx;
}

.news-swiper-wrap {
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.news-slide {
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
}

.news-slide-img {
  border-radius: 24rpx;
}

.news-slide-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 28rpx 28rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.6) 100%);
}

.news-slide-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.news-slide-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.swiper-indicator-custom {
  display: flex;
  flex-direction: row;
  justify-content: center;
  padding: 20rpx 0 4rpx;
}

.indicator-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #d8d8d8;
  margin: 0 8rpx;
  transition: all 0.3s ease;
}

.indicator-dot-active {
  width: 32rpx;
  border-radius: 6rpx;
  background-color: #07c160;
}

/* ========== 底部安全距离 ========== */
.bottom-safe {
  height: calc(40rpx + constant(safe-area-inset-bottom));
  height: calc(40rpx + env(safe-area-inset-bottom));
}
