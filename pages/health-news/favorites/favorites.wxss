.favorites-container {
  min-height: 100vh;
  background-color: #f6f6f6;
}

.list {
  padding: 16rpx 24rpx;
}

.swipe-delete {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 130rpx;
  height: 100%;
  background-color: #ee0a24;
  color: #ffffff;
  font-size: 26rpx;
}

.page-loading {
  padding-top: 200rpx;
}

.no-more {
  text-align: center;
  padding: 32rpx 0;
}

.bottom-safe {
  height: calc(40rpx + constant(safe-area-inset-bottom));
  height: calc(40rpx + env(safe-area-inset-bottom));
}
