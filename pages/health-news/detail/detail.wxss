.detail-container {
  min-height: 100vh;
  background-color: #ffffff;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.page-loading {
  padding-top: 300rpx;
}

.article-cover {
  width: 100%;
}

.cover-img {
  width: 100%;
  height: 500rpx;
}

.article-header {
  padding: 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.article-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.5;
}

.article-meta {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 16rpx;
}

/* 操作栏 */
.action-bar {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  padding: 24rpx 0;
  border-bottom: 6rpx solid #f6f6f6;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 20rpx;
}

/* 富文本内容 */
.article-content {
  padding: 32rpx;
}

.article-text {
  font-size: 30rpx;
  line-height: 2;
  color: #323233;
  white-space: pre-wrap;
  word-break: break-all;
}

.rich-text-content {
  font-size: 30rpx;
  line-height: 1.8;
  color: #323233;
}

.article-divider {
  height: 12rpx;
  background-color: #f6f6f6;
}

/* 评论区 */
.comment-section {
  padding: 0 32rpx;
}

.section-header {
  padding: 28rpx 0 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
}

/* 底部评论输入栏 */
.comment-input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
  z-index: 10;
}

.input-placeholder {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #f7f8fa;
  border-radius: 36rpx;
  padding: 16rpx 28rpx;
}

/* 评论弹窗 */
.comment-popup {
  padding: 24rpx 0;
}

.comment-popup-header {
  padding: 0 32rpx 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.comment-popup-body {
  padding: 8rpx 16rpx;
}

.comment-textarea {
  min-height: 160rpx;
}

.comment-popup-footer {
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
  padding: 16rpx 32rpx;
}

.comment-popup-footer van-button:first-child {
  margin-right: 16rpx;
}

.bottom-safe {
  height: calc(120rpx + constant(safe-area-inset-bottom));
  height: calc(120rpx + env(safe-area-inset-bottom));
}
