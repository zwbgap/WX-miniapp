.stats-container {
  min-height: 100vh;
  background-color: #f6f6f6;
}

.page-loading {
  padding-top: 300rpx;
}

/* 概览数据 */
.overview-row {
  display: flex;
  flex-direction: row;
  margin: 24rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx 0;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.overview-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.overview-item + .overview-item {
  border-left: 1rpx solid #f0f0f0;
}

.overview-value {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.2;
}

.overview-value.primary {
  color: #1989fa;
}

.overview-label {
  font-size: 22rpx;
  color: #969799;
  margin-top: 8rpx;
}

/* 最佳最差标签 */
.best-worst-row {
  display: flex;
  flex-direction: row;
  padding: 0 24rpx 8rpx;
}

.best-badge,
.worst-badge {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  margin-right: 16rpx;
  background-color: #ffffff;
}

/* 卡片 */
.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  margin: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-left: 12rpx;
}

/* 趋势图 */
.chart-wrap {
  width: 100%;
}

.sleep-chart {
  display: block;
}

/* 质量分布 */
.dist-list {
  padding: 8rpx 0;
}

.dist-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 0;
}

.dist-label {
  display: flex;
  flex-direction: row;
  align-items: center;
  width: 100rpx;
  flex-shrink: 0;
}

.dist-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.dist-bar-wrap {
  flex: 1;
  padding-left: 16rpx;
}

.bottom-safe {
  height: calc(40rpx + constant(safe-area-inset-bottom));
  height: calc(40rpx + env(safe-area-inset-bottom));
}
