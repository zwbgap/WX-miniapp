.list-container {
  min-height: 100vh;
  background-color: #f6f6f6;
}

/* 日期筛选栏 */
.filter-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 12rpx 24rpx;
  background-color: #f7f8fa;
  border-radius: 32rpx;
}

.filter-item.filter-active {
  background-color: rgba(25, 137, 250, 0.08);
}

.clear-filter {
  color: #ee0a24;
}

/* 记录卡片 */
.record-list {
  padding: 16rpx 24rpx;
}

.record-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.record-card-header {
  margin-bottom: 16rpx;
}

.record-date-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.record-date-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #1989fa, #07c160);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.date-day {
  font-size: 22rpx;
  font-weight: 600;
  color: #ffffff;
  text-align: center;
  line-height: 1.4;
}

.record-date-info {
  flex: 1;
}

.sleep-time-range {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.record-card-body {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-top: 1rpx solid #f5f5f5;
  border-bottom: 1rpx solid #f5f5f5;
}

.duration-block {
  display: flex;
  flex-direction: row;
  align-items: baseline;
}

.duration-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #1989fa;
}

.duration-label {
  font-size: 22rpx;
  color: #969799;
  margin-left: 8rpx;
}

.quality-block {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.quality-stars {
  font-size: 24rpx;
  color: #ff976a;
  margin-right: 12rpx;
  letter-spacing: 2rpx;
}

.record-card-footer {
  margin-top: 16rpx;
}

.record-note {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 左滑删除 */
.swipe-delete {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 130rpx;
  height: 100%;
  background-color: #ee0a24;
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 0 20rpx 20rpx 0;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: calc(32rpx + constant(safe-area-inset-bottom));
  bottom: calc(32rpx + env(safe-area-inset-bottom));
  left: 24rpx;
  right: 24rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  background-color: #ffffff;
  padding: 16rpx 28rpx;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.stat-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 12rpx;
}

.page-loading {
  padding-top: 200rpx;
}

.loading-more,
.no-more {
  text-align: center;
  padding: 32rpx 0;
}

.bottom-safe {
  height: calc(160rpx + constant(safe-area-inset-bottom));
  height: calc(160rpx + env(safe-area-inset-bottom));
}
