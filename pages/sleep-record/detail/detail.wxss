.edit-container {
  min-height: 100vh;
  background-color: #f6f6f6;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.page-loading {
  padding-top: 300rpx;
}

.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  margin: 24rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.card-title-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-left: 12rpx;
}

/* 入睡 / 起床时间选择 */
.time-pick-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  padding: 32rpx 0;
}

.time-pick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.time-pick-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.moon-placeholder {
  font-size: 48rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sun-placeholder {
  font-size: 48rpx;
  background: linear-gradient(135deg, #ff976a, #ffc837);
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.time-pick-label {
  font-size: 24rpx;
  color: #969799;
  margin-bottom: 8rpx;
}

.time-pick-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #323233;
  background-color: #f7f8fa;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
}

.time-pick-divider {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 20rpx;
}

.divider-line {
  width: 2rpx;
  height: 40rpx;
  background-color: #e8e8e8;
}

.divider-icon {
  padding: 4rpx 0;
}

/* 睡眠时长显示 */
.duration-display {
  text-align: center;
  padding: 20rpx 0 8rpx;
  border-top: 1rpx solid #f5f5f5;
}

.duration-text {
  font-size: 26rpx;
  color: #969799;
}

.duration-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #1989fa;
}

/* 睡眠质量评分 */
.rate-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 16rpx;
}

.rate-text {
  font-size: 28rpx;
  color: #ff976a;
  margin-top: 16rpx;
  font-weight: 500;
}

/* 操作按钮 */
.action-bar {
  display: flex;
  flex-direction: row;
  padding: 48rpx 24rpx;
}

.action-bar van-button:first-child {
  flex: 1;
  margin-right: 24rpx;
}

.action-bar van-button:last-child {
  flex: 2;
}

.bottom-safe {
  height: calc(60rpx + constant(safe-area-inset-bottom));
  height: calc(60rpx + env(safe-area-inset-bottom));
}
