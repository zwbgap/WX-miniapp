.debug-container {
  padding: 20rpx;
  background-color: #1e1e1e;
  min-height: 100vh;
}

.header {
  padding: 20rpx;
  background-color: #2d2d2d;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 700;
  color: #4ec9b0;
  display: block;
}

.uid {
  font-size: 22rpx;
  color: #808080;
  margin-top: 8rpx;
  display: block;
}

.btn-group {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.debug-btn {
  flex-shrink: 0;
}

.log-area {
  background-color: #2d2d2d;
  border-radius: 12rpx;
  padding: 16rpx;
  max-height: calc(100vh - 350rpx);
  overflow-y: auto;
}

.log-item {
  padding: 6rpx 0;
  border-bottom: 1rpx solid #3d3d3d;
}

.log-time {
  font-size: 20rpx;
  color: #808080;
  margin-right: 12rpx;
}

.log-text {
  font-size: 24rpx;
  color: #d4d4d4;
  word-break: break-all;
  font-family: monospace;
}
