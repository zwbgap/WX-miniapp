.reminder-item {
  margin: 16rpx 24rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.reminder-item.hover-class {
  background: #f5f5f5;
}

.reminder-top {
  display: flex;
  align-items: center;
}

.reminder-icon {
  margin-right: 16rpx;
}

.reminder-info {
  flex: 1;
  min-width: 0;
}

.reminder-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.reminder-location {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.reminder-bottom {
  margin-top: 16rpx;
}

.add-btn {
  position: fixed;
  bottom: 64rpx;
  left: 32rpx;
  right: 32rpx;
}

.loading-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 32rpx 0;
}

.no-more {
  text-align: center;
  padding: 32rpx 0;
}
