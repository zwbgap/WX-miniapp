.list-container {
  min-height: 100vh;
  background-color: #f6f6f6;
}

.stats-bar {
  display: flex;
  flex-direction: row;
  background: linear-gradient(135deg, #ff976a, #ff6b3d);
  padding: 32rpx 0;
  margin: 0 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 151, 106, 0.3);
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-item + .stats-item {
  border-left: 2rpx solid rgba(255, 255, 255, 0.3);
}

.stats-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.2;
}

.stats-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 6rpx;
}

.action-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  padding: 16rpx 32rpx;
}

.action-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 8rpx 20rpx;
  background-color: #fff5f0;
  border-radius: 24rpx;
  margin-left: 16rpx;
}

.record-list {
  padding: 0 24rpx;
}

.record-item {
  background-color: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.record-item-hover {
  background-color: #f7f8fa;
  opacity: 0.9;
}

.record-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 16rpx;
}

.record-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background-color: #fff5f0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.record-info {
  flex: 1;
}

.record-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
  line-height: 1.4;
}

.record-location {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 6rpx;
}

.record-bottom {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.record-date {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.record-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.action-text {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.action-done {
  color: #07c160;
  background-color: #f0faf3;
}

.action-delete {
  color: #ee0a24;
  background-color: #fef0f0;
}

.bottom-safe {
  height: calc(100rpx + constant(safe-area-inset-bottom));
  height: calc(100rpx + env(safe-area-inset-bottom));
}
