<view class="edit-container">
  <van-loading wx:if="{{loading}}" custom-class="page-loading" />

  <block wx:else>
    <view class="card">
      <view class="card-header">
        <view class="card-dot" style="background-color: #07c160;"></view>
        <text class="card-title">账号信息</text>
      </view>

      <van-field
        label="用户名"
        value="{{form.nickName}}"
        placeholder="请输入用户名"
        left-icon="user-o"
        clearable
        required
        data-field="nickName"
        bind:change="onFieldChange"
      />

      <view class="field-row">
        <text class="field-label">登录账号</text>
        <text class="field-value text-secondary">{{form.accountId || '--'}}</text>
      </view>
    </view>

    <view class="card">
      <view class="card-header">
        <view class="card-dot" style="background-color: #1989fa;"></view>
        <text class="card-title">基本信息</text>
      </view>

      <van-field
        label="姓名"
        value="{{form.xingming}}"
        placeholder="请输入姓名"
        left-icon="contact-o"
        clearable
        required
        data-field="xingming"
        bind:change="onFieldChange"
      />

      <van-field
        label="年龄"
        value="{{form.nianling}}"
        type="number"
        placeholder="请输入年龄"
        left-icon="birthday-cake-o"
        clearable
        required
        data-field="nianling"
        bind:change="onFieldChange"
      />

      <van-field
        label="血型"
        value="{{form.xuexing}}"
        placeholder="请选择血型"
        left-icon="birthday-cake-o"
        type="text"
        clearable
        required
        data-field="xuexing"
        bind:change="onFieldChange"
      />

      <van-field label="身高" value="{{form.shengao}}" type="number" placeholder="请输入身高(cm)" left-icon="ascending" clearable required data-field="shengao" bind:change="onFieldChange" />
    </view>

    <view class="card">
      <view class="card-header">
        <view class="card-dot" style="background-color: #07c160;"></view>
        <text class="card-title">绑定医生</text>
      </view>

      <view class="doctor-bind-section">
        <van-field
          label="绑定医生"
          value="{{selectedDoctorName}}"
          placeholder="请选择医生"
          left-icon="user-circle-o"
          is-link
          readonly
          bind:tap="onOpenDoctorPicker"
        />
        
        <view wx:if="{{selectedDoctor}}" class="doctor-info">
          <view class="doctor-info-row">
            <text class="doctor-info-label">工号</text>
            <text class="doctor-info-value">{{selectedDoctor.employeeId || '--'}}</text>
          </view>
          <view class="doctor-info-row">
            <text class="doctor-info-label">科室</text>
            <text class="doctor-info-value">{{selectedDoctor.department || '--'}}</text>
          </view>
          <view class="doctor-info-row">
            <text class="doctor-info-label">职称</text>
            <text class="doctor-info-value">{{selectedDoctor.title || '--'}}</text>
          </view>
          <view class="doctor-info-row">
            <text class="doctor-info-label">电话</text>
            <text class="doctor-info-value">{{selectedDoctor.phone || '--'}}</text>
          </view>
          
          <view class="unbind-section">
            <van-button type="danger" size="small" block bind:tap="onUnbindDoctor">
              解除绑定
            </van-button>
          </view>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="card-header">
        <view class="card-dot" style="background-color: #ee0a24;"></view>
        <text class="card-title">家族病史</text>
      </view>

      <view class="field-row">
        <text class="field-label">高血压</text>
        <van-radio-group value="{{form.jiazu_gaoxueya}}" direction="horizontal" bind:change="onRadioChange" data-field="jiazu_gaoxueya">
          <van-radio name="有" checked-color="#ee0a24" icon-size="28rpx">有</van-radio>
          <van-radio name="无" checked-color="#07c160" icon-size="28rpx">无</van-radio>
          <van-radio name="不详" checked-color="#969799" icon-size="28rpx">不详</van-radio>
        </van-radio-group>
      </view>

      <view class="field-row">
        <text class="field-label">糖尿病</text>
        <van-radio-group value="{{form.jiazu_tangniaobing}}" direction="horizontal" bind:change="onRadioChange" data-field="jiazu_tangniaobing">
          <van-radio name="有" checked-color="#ee0a24" icon-size="28rpx">有</van-radio>
          <van-radio name="无" checked-color="#07c160" icon-size="28rpx">无</van-radio>
          <van-radio name="不详" checked-color="#969799" icon-size="28rpx">不详</van-radio>
        </van-radio-group>
      </view>

      <view class="field-row">
        <text class="field-label">心脏病</text>
        <van-radio-group value="{{form.jiazu_xinzang}}" direction="horizontal" bind:change="onRadioChange" data-field="jiazu_xinzang">
          <van-radio name="有" checked-color="#ee0a24" icon-size="28rpx">有</van-radio>
          <van-radio name="无" checked-color="#07c160" icon-size="28rpx">无</van-radio>
          <van-radio name="不详" checked-color="#969799" icon-size="28rpx">不详</van-radio>
        </van-radio-group>
      </view>

      <van-field label="其他病史" value="{{form.jiazu_qita}}" type="textarea" placeholder="请输入其他家族病史" autosize left-icon="notes-o" data-field="jiazu_qita" bind:change="onFieldChange" />
    </view>

    <view class="card">
      <view class="card-header">
        <view class="card-dot" style="background-color: #1989fa;"></view>
        <text class="card-title">应急信息</text>
      </view>

      <van-field label="紧急联系人" value="{{form.jinji_lianxiren}}" placeholder="请输入姓名" left-icon="contact-o" clearable data-field="jinji_lianxiren" bind:change="onFieldChange" />
      <van-field label="联系电话" value="{{form.jinji_dianhua}}" type="number" placeholder="请输入手机号" left-icon="phone-o" clearable data-field="jinji_dianhua" bind:change="onFieldChange" />

      <view class="field-row">
        <text class="field-label">医保类型</text>
        <van-radio-group value="{{form.jinji_yibao}}" direction="horizontal" bind:change="onRadioChange" data-field="jinji_yibao">
          <van-radio name="职工医保" checked-color="#1989fa" icon-size="28rpx">职工</van-radio>
          <van-radio name="居民医保" checked-color="#1989fa" icon-size="28rpx">居民</van-radio>
          <van-radio name="商业保险" checked-color="#1989fa" icon-size="28rpx">商业</van-radio>
          <van-radio name="自费" checked-color="#1989fa" icon-size="28rpx">自费</van-radio>
        </van-radio-group>
      </view>

      <view class="field-row">
        <text class="field-label">植入器械</text>
        <van-radio-group value="{{form.jinjicheng_duixiang}}" direction="horizontal" bind:change="onRadioChange" data-field="jinjicheng_duixiang">
          <van-radio name="无" checked-color="#07c160" icon-size="28rpx">无</van-radio>
          <van-radio name="心脏起搏器" checked-color="#ee0a24" icon-size="28rpx">起搏器</van-radio>
          <van-radio name="支架" checked-color="#ee0a24" icon-size="28rpx">支架</van-radio>
          <van-radio name="其他" checked-color="#ff976a" icon-size="28rpx">其他</van-radio>
        </van-radio-group>
      </view>
    </view>

    <view class="action-bar">
      <van-button size="large" round plain hairline type="default" bind:tap="onCancel">取消</van-button>
      <van-button size="large" round type="primary" loading="{{submitting}}" loading-text="保存中..." bind:tap="onSubmit">保存</van-button>
    </view>
  </block>

  <van-popup show="{{pickerVisible}}" position="bottom" round bind:close="onPickerCancel">
    <van-picker columns="{{bloodTypeColumns}}" default-index="{{pickerValue}}" show-toolbar title="选择血型" bind:confirm="onPickerConfirm" bind:cancel="onPickerCancel" />
  </van-popup>

  <van-popup show="{{doctorPickerVisible}}" position="bottom" round custom-style="height: 75%;">
    <view class="doctor-picker-header">
      <text class="picker-title">选择医生</text>
      <van-button type="text" size="small" bind:tap="onDoctorPickerCancel">取消</van-button>
    </view>
    <scroll-view scroll-y class="doctor-picker-content">
      <view wx:if="{{doctors.length === 0}}" class="empty-state">
        <text class="empty-icon">👨‍⚕️</text>
        <text class="empty-text">暂无医生</text>
      </view>
      <view wx:else>
        <view 
          wx:for="{{doctors}}" 
          wx:key="_id" 
          class="doctor-picker-item"
          class="{{selectedDoctorId === item._id ? 'selected' : ''}}"
          bind:tap="onSelectDoctor"
          data-id="{{item._id}}"
        >
          <view class="doctor-picker-avatar">👨‍⚕️</view>
          <view class="doctor-picker-info">
            <view class="doctor-picker-name">{{item.nickName || item.account}}</view>
            <view class="doctor-picker-detail">
              <text wx:if="{{item.department}}" class="detail-tag">{{item.department}}</text>
              <text wx:if="{{item.employeeId}}" class="detail-tag">{{item.employeeId}}</text>
              <text wx:if="{{item.title}}" class="detail-tag">{{item.title}}</text>
            </view>
          </view>
          <view wx:if="{{selectedDoctorId === item._id}}" class="doctor-picker-check">✓</view>
        </view>
      </view>
    </scroll-view>
    <view class="doctor-picker-footer">
      <van-button 
        size="large" 
        round 
        block 
        type="primary" 
        disabled="{{!selectedDoctorId}}"
        bind:tap="onDoctorPickerConfirm"
      >
        确认绑定
      </van-button>
    </view>
  </van-popup>

  <view class="bottom-safe"></view>
</view>