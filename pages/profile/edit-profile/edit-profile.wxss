.edit-container {
  min-height: 100vh;
  background-color: #f6f6f6;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.page-loading {
  padding-top: 300rpx;
}

.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  margin: 24rpx;
  padding: 32rpx 0 0;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 0 32rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  margin-bottom: 0;
}

.card-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.card-hint {
  font-size: 24rpx;
  color: #969799;
  margin-left: 12rpx;
}

.field-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.field-label {
  width: 180rpx;
  font-size: 28rpx;
  color: #323233;
}

.field-value {
  font-size: 28rpx;
  flex: 1;
}

.text-secondary {
  color: #969799;
}

.doctor-bind-section {
  padding: 0 32rpx 24rpx;
}

.doctor-info {
  background-color: #f8fafc;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-top: 16rpx;
}

.doctor-info-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 12rpx 0;
}

.doctor-info-label {
  width: 100rpx;
  font-size: 26rpx;
  color: #969799;
}

.doctor-info-value {
  font-size: 26rpx;
  color: #323233;
  flex: 1;
}

.unbind-section {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx dashed #e2e8f0;
}

.action-bar {
  display: flex;
  flex-direction: row;
  padding: 48rpx 24rpx;
}

.action-bar van-button:first-child {
  flex: 1;
  margin-right: 24rpx;
}

.action-bar van-button:last-child {
  flex: 2;
}

.bottom-safe {
  height: constant(safe-area-inset-bottom);
  height: env(safe-area-inset-bottom);
}

.doctor-picker-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.doctor-picker-content {
  height: calc(100% - 180rpx);
  padding: 16rpx;
}

.doctor-picker-footer {
  padding: 20rpx 24rpx;
  border-top: 1rpx solid #f5f5f5;
  background-color: #ffffff;
}

.doctor-picker-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s ease;
}

.doctor-picker-item:active {
  background-color: #f5f5f5;
}

.doctor-picker-item.selected {
  background-color: #ecfdf5;
  border: 2rpx solid #07c160;
}

.doctor-picker-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07c160 0%, #06b6d4 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.doctor-picker-info {
  flex: 1;
}

.doctor-picker-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.doctor-picker-detail {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.detail-tag {
  font-size: 22rpx;
  color: #64748b;
  background-color: #f1f5f9;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.doctor-picker-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background-color: #07c160;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #969799;
}