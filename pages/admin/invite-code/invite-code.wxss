.invite-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 60rpx;
}

.page-header {
  background: linear-gradient(135deg, #07c160 0%, #06b6d4 100%);
  padding: 60rpx 32rpx 40rpx;
  color: #ffffff;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

.form-section {
  background-color: #ffffff;
  margin: -30rpx 32rpx 32rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.tip-section {
  background-color: #f5f5f5;
  padding: 24rpx;
  border-radius: 12rpx;
  margin: 24rpx 0;
}

.tip-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #646566;
  line-height: 1.8;
}

.codes-section {
  background-color: #ffffff;
  margin: 0 32rpx 32rpx;
  padding: 32rpx;
  border-radius: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

.codes-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.code-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
}

.code-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #07c160;
  font-family: monospace;
  flex: 1;
}

.code-info {
  font-size: 24rpx;
  color: #969799;
  margin-right: 16rpx;
}

.copy-btn {
  padding: 8rpx 24rpx;
  background-color: #07c160;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.history-section {
  margin: 0 32rpx;
}

.empty-state {
  text-align: center;
  padding: 60rpx;
  color: #969799;
  font-size: 28rpx;
}

.used-status {
  color: #969799;
}

.unused-status {
  color: #07c160;
}