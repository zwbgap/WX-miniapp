.invite-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 60rpx;
}

.page-header {
  background: linear-gradient(135deg, #07c160 0%, #06b6d4 100%);
  padding: 60rpx 32rpx 40rpx;
  color: #ffffff;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

.form-section {
  background-color: #ffffff;
  margin: -30rpx 32rpx 32rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.tip-section {
  background-color: #f5f5f5;
  padding: 24rpx;
  border-radius: 12rpx;
  margin: 24rpx 0;
}

.tip-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #646566;
  line-height: 1.8;
}

.codes-section {
  background-color: #ffffff;
  margin: 0 32rpx 32rpx;
  padding: 32rpx;
  border-radius: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

.codes-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.code-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
}

.code-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #07c160;
  font-family: monospace;
  flex: 1;
}

.code-info {
  font-size: 24rpx;
  color: #969799;
  margin-right: 16rpx;
}

.copy-btn {
  padding: 8rpx 24rpx;
  background-color: #07c160;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.history-section {
  margin: 0 32rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
  border-bottom: 2rpx solid #f0f0f0;
}

.invite-code {
  font-size: 36rpx;
  font-weight: 800;
  color: #07c160;
  font-family: 'Consolas', 'Monaco', monospace;
  letter-spacing: 2rpx;
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.status-badge.unused {
  background-color: #e8f7ef;
  color: #07c160;
}

.status-badge.used {
  background-color: #f5f5f5;
  color: #969799;
}

.card-body {
  padding: 24rpx 32rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #969799;
}

.info-value {
  font-size: 26rpx;
  color: #323233;
  font-weight: 500;
}

.doctor-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.doctor-name {
  color: #07c160;
  font-weight: 600;
}

.doctor-account {
  color: #969799;
  font-size: 24rpx;
}

.empty-state {
  text-align: center;
  padding: 60rpx;
  color: #969799;
  font-size: 28rpx;
}