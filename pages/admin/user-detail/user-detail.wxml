<view class="user-detail-container">
  <van-loading wx:if="{{loading}}" custom-class="page-loading" />

  <block wx:elif="{{profile}}">
    <view class="profile-header">
      <view class="header-bg"></view>
      <view class="header-content">
        <view class="user-avatar">
          <image wx:if="{{user.avatarUrl}}" src="{{user.avatarUrl}}" mode="aspectFill" />
          <text wx:else>👤</text>
        </view>
        <view class="user-name">{{profile.xingming || user.nickName || user.account}}</view>
        <view class="user-badge">账号: {{user.account}}</view>
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">基本信息</view>

      <view class="form-card">
        <view class="info-row">
          <view class="info-label">姓名</view>
          <view class="info-value">{{profile.xingming || '未填写'}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">年龄</view>
          <view class="info-value">{{profile.nianling || '未填写'}} 岁</view>
        </view>
        <view class="info-row">
          <view class="info-label">血型</view>
          <view class="info-value">{{profile.xuexing || '未填写'}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">身高</view>
          <view class="info-value">{{profile.shengao || '未填写'}} cm</view>
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">家族病史</view>

      <view class="form-card">
        <view class="info-row">
          <view class="info-label">高血压</view>
          <view class="info-value">{{profile.jiazu_gaoxueya || '无'}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">糖尿病</view>
          <view class="info-value">{{profile.jiazu_tangniaobing || '无'}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">心脏病</view>
          <view class="info-value">{{profile.jiazu_xinzang || '无'}}</view>
        </view>
        <view class="info-row" wx:if="{{profile.jiazu_qita}}">
          <view class="info-label">其他</view>
          <view class="info-value">{{profile.jiazu_qita}}</view>
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">紧急联系人</view>

      <view class="form-card">
        <view class="info-row">
          <view class="info-label">联系人</view>
          <view class="info-value">{{profile.jinji_lianxiren || '未填写'}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">联系电话</view>
          <view class="info-value">{{profile.jinji_dianhua || '未填写'}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">医保类型</view>
          <view class="info-value">{{profile.jinji_yibao || '未填写'}}</view>
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">绑定信息</view>

      <view class="form-card">
        <view class="info-row">
          <view class="info-label">绑定状态</view>
          <view class="info-value {{doctorInfo ? 'bound' : 'unbound'}}">
            {{doctorInfo ? '已绑定医生' : '未绑定'}}
          </view>
        </view>
        <view class="info-row" wx:if="{{doctorInfo}}">
          <view class="info-label">绑定医生</view>
          <view class="info-value doctor-name">{{doctorInfo.nickName || doctorInfo.account}}</view>
        </view>
        <view class="info-row" wx:if="{{doctorInfo}}">
          <view class="info-label">医生科室</view>
          <view class="info-value">{{doctorInfo.department || '未填写'}}</view>
        </view>
        <view class="info-row" wx:if="{{doctorInfo}}">
          <view class="info-label">医生电话</view>
          <view class="info-value">{{doctorInfo.phone || '未填写'}}</view>
        </view>
      </view>
    </view>
  </block>

  <block wx:elif="{{!loading}}">
    <view class="empty-state">
      <text class="empty-icon">📋</text>
      <text class="empty-text">该用户暂未填写健康档案</text>
    </view>
  </block>

  <view class="bottom-safe"></view>
</view>