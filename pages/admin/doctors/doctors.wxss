.doctors-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.doctors-list {
  padding: 16rpx 0;
}

.doctor-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  overflow: hidden;
}

.doctor-avatar image {
  width: 100%;
  height: 100%;
}

.doctor-avatar text {
  font-size: 48rpx;
}

.swipe-action {
  height: 100%;
  display: flex;
}

.delete-btn {
  background-color: #dc3545;
  color: #ffffff;
  padding: 0 40rpx;
  display: flex;
  align-items: center;
  height: 100%;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #969799;
}