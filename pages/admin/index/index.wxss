.admin-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: calc(var(--status-bar-height) + 88rpx);
  background-color: #ffffff;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 20rpx;
  z-index: 100;
  border-bottom: 1rpx solid #f0f0f0;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.admin-header {
  position: relative;
  height: 400rpx;
  padding-top: calc(var(--status-bar-height) + 88rpx);
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #07c160 0%, #06b6d4 100%);
  border-radius: 0 0 48rpx 48rpx;
}

.header-content {
  position: relative;
  padding: 80rpx 32rpx 40rpx;
  z-index: 1;
}

.admin-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.admin-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(255,255,255,0.3) 0%, rgba(255,255,255,0.1) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  margin-bottom: 20rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.admin-badge {
  background-color: rgba(255, 255, 255, 0.25);
  color: #ffffff;
  padding: 10rpx 28rpx;
  border-radius: 28rpx;
  font-size: 24rpx;
  margin-bottom: 16rpx;
  backdrop-filter: blur(10px);
}

.admin-name {
  font-size: 38rpx;
  font-weight: 600;
  color: #ffffff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.menu-section {
  background-color: #ffffff;
  margin: 20rpx 32rpx 32rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.1);
}

.menu-title {
  padding: 32rpx 32rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item {
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #f8f8f8;
  transition: background-color 0.2s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #f9f9f9;
}

.menu-item-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 24rpx;
}

.menu-item-text {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.menu-item-arrow {
  width: 24rpx;
  height: 24rpx;
  border-right: 3rpx solid #cccccc;
  border-bottom: 3rpx solid #cccccc;
  transform: rotate(-45deg);
}

.icon-blue {
  background-color: #dbeafe;
}

.icon-green {
  background-color: #dcfce7;
}

.icon-orange {
  background-color: #ffedd5;
}

.icon-purple {
  background-color: #ede9fe;
}

.icon-red {
  background-color: #fee2e2;
}

.danger-section {
  background-color: #ffffff;
  margin: 0 32rpx 32rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.1);
}

.logout-section {
  padding: 0 32rpx 80rpx;
}

.logout-btn {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  color: #ffffff;
  border: none;
  border-radius: 16rpx;
  height: 100rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(239, 68, 68, 0.3);
}

.logout-btn:active {
  transform: scale(0.98);
}
