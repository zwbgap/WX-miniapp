<view class="login-container">
  <view class="login-header">
    <image class="login-logo" src="/images/logo.png" mode="aspectFit" />
    <view class="login-title">健康小助手</view>
    <view class="login-subtitle">登录即享专属健康管理服务</view>
  </view>

  <!-- 身份选择 -->
  <view class="identity-selector">
    <view class="selector-title">选择身份</view>
    <view class="identity-options">
      <view 
        class="identity-option {{identity === 'user' ? 'active' : ''}}" 
        bind:tap="onSelectIdentity"
        data-identity="user"
      >
        <view class="identity-icon">👤</view>
        <text class="identity-label">用户</text>
      </view>
      <view 
        class="identity-option {{identity === 'doctor' ? 'active' : ''}}" 
        bind:tap="onSelectIdentity"
        data-identity="doctor"
      >
        <view class="identity-icon">👨‍⚕️</view>
        <text class="identity-label">医生</text>
      </view>
      <view 
        class="identity-option {{identity === 'admin' ? 'active' : ''}}" 
        bind:tap="onSelectIdentity"
        data-identity="admin"
      >
        <view class="identity-icon">🔐</view>
        <text class="identity-label">管理员</text>
      </view>
    </view>
  </view>

  <!-- 账号密码登录 -->
  <view class="account-login-panel">
    <van-cell-group>
      <van-field
        value="{{account}}"
        placeholder="请输入账号"
        left-icon="user-o"
        clearable
        bind:input="onAccountInput"
      />
      <view class="password-input-wrapper">
        <van-field
          value="{{password}}"
          type="{{passwordVisible ? 'text' : 'password'}}"
          placeholder="请输入密码"
          left-icon="lock"
          bind:input="onPasswordInput"
        />
        <view class="custom-eye-icon" bind:tap="onTogglePasswordVisible">
          <text wx:if="{{passwordVisible}}">👁️</text>
          <text wx:else>🙈</text>
        </view>
      </view>
    </van-cell-group>

    <view class="account-options">
      <van-checkbox
        value="{{rememberPassword}}"
        checked-color="#07c160"
        icon-size="32rpx"
        bind:change="onToggleRemember"
      >
        <text class="text-sm" style="color: #646566;">记住密码</text>
      </van-checkbox>
    </view>

    <van-button
      type="primary"
      size="large"
      round
      block
      loading="{{accountLoading}}"
      loading-text="登录中..."
      bind:tap="onAccountLogin"
    >
      {{identity === 'doctor' ? '医生登录' : identity === 'admin' ? '管理员登录' : '用户登录'}}
    </van-button>
  </view>

  <view class="login-footer" wx:if="{{identity === 'user'}}">
    <text class="text-sm text-secondary">还没有账号？</text>
    <text class="text-sm register-link" bind:tap="onGoRegister">立即注册</text>
  </view>
  <view class="login-footer" wx:if="{{identity === 'doctor'}}">
    <text class="text-sm text-secondary">还没有账号？</text>
    <text class="text-sm register-link" bind:tap="onGoRegister">立即注册</text>
  </view>
  <view class="login-footer doctor-tip" wx:if="{{identity === 'admin'}}">
    <text class="text-sm text-secondary">管理员拥有最高权限</text>
  </view>
</view>