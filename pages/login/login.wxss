.login-container {
  min-height: 100vh;
  background-color: #ffffff;
  padding: 0 48rpx;
  box-sizing: border-box;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
  padding-bottom: 48rpx;
}

.login-logo {
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 24rpx;
}

.login-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.login-subtitle {
  font-size: 26rpx;
  color: #969799;
}

/* 身份选择器 */
.identity-selector {
  padding: 16rpx 0;
  margin-bottom: 8rpx;
}

.selector-title {
  font-size: 24rpx;
  color: #969799;
  text-align: center;
  margin-bottom: 16rpx;
}

.identity-options {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 32rpx;
}

.identity-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
  transition: all 0.3s;
  min-width: 120rpx;
}

.identity-option.active {
  background-color: #07c160;
}

.identity-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-bottom: 8rpx;
  background-color: rgba(255, 255, 255, 0.8);
}

.identity-option.active .identity-icon {
  background-color: rgba(255, 255, 255, 0.95);
}

.identity-label {
  font-size: 24rpx;
  color: #646566;
}

.identity-option.active .identity-label {
  color: #ffffff;
  font-weight: 600;
}

/* 账号登录面板 */
.account-login-panel {
  padding-top: 8rpx;
}

.account-options {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 16rpx 40rpx;
}

.forgot-pwd {
  color: #1989fa;
}

.login-footer {
  text-align: center;
  padding: 40rpx 0 20rpx;
}

.register-link {
  color: #07c160;
  margin-left: 8rpx;
}

.doctor-tip {
  font-size: 24rpx;
  color: #969799;
}