.login-container {
  min-height: 100vh;
  background-color: #ffffff;
  padding: 0 48rpx;
  box-sizing: border-box;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
  padding-bottom: 48rpx;
}

.login-logo {
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 24rpx;
}

.login-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.login-subtitle {
  font-size: 26rpx;
  color: #969799;
}

/* 登录方式Tab */
.login-tabs {
  display: flex;
  flex-direction: row;
  margin-bottom: 48rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.login-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 30rpx;
  color: #969799;
  position: relative;
  transition: color 0.3s;
}

.login-tab.tab-active {
  color: #07c160;
  font-weight: 600;
}

.login-tab.tab-active::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background-color: #07c160;
  border-radius: 3rpx;
}

/* 微信登录面板 */
.wechat-login-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 40rpx;
}

.wechat-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: #f0faf3;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.wechat-login-desc {
  font-size: 28rpx;
  color: #969799;
  margin-bottom: 48rpx;
}

/* 账号登录面板 */
.account-login-panel {
  padding-top: 8rpx;
}

.account-options {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 16rpx 40rpx;
}

.forgot-pwd {
  color: #1989fa;
}

.register-link {
  text-align: center;
  padding: 40rpx 0 20rpx;
}

.link-text {
  color: #07c160;
  margin-left: 8rpx;
}

/* 协议区域 */
.agreement-section {
  position: fixed;
  bottom: calc(80rpx + constant(safe-area-inset-bottom));
  bottom: calc(80rpx + env(safe-area-inset-bottom));
  left: 48rpx;
  right: 48rpx;
}

.agreement-text {
  color: #969799;
  line-height: 1.6;
}
