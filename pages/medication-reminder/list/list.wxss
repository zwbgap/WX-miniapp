.list-container {
  min-height: 100vh;
  background-color: #f6f6f6;
}

/* 今日用药卡片 */
.today-card {
  position: relative;
  margin: 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.today-card-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #ee0a24, #c80820);
  z-index: 0;
}

.today-card-content {
  position: relative;
  z-index: 1;
  padding: 28rpx 32rpx;
}

.today-card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.today-title-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.today-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  margin-left: 12rpx;
}

.today-progress-badge {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 600;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 4rpx 20rpx;
  border-radius: 20rpx;
}

.today-progress-bar {
  height: 8rpx;
  background-color: rgba(255, 255, 255, 0.25);
  border-radius: 4rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.today-progress-fill {
  height: 100%;
  background-color: #07c160;
  border-radius: 4rpx;
  transition: width 0.4s ease;
}

.today-med-list {
  display: flex;
  flex-direction: column;
}

.today-med-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.12);
}

.today-med-item:last-child {
  border-bottom: none;
}

.today-med-item.med-checked {
  opacity: 0.7;
}

.today-med-check {
  margin-right: 20rpx;
}

.today-med-info {
  flex: 1;
}

.today-med-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

.today-med-meta {
  display: flex;
  flex-direction: row;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 4rpx;
  font-size: 22rpx;
}

.today-card-footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.12);
  margin-top: 8rpx;
}

/* 操作栏 */
.action-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
}

.tabs-row {
  display: flex;
  flex-direction: row;
}

.mini-tab {
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  color: #969799;
  background-color: #ffffff;
  border-radius: 24rpx;
  margin-right: 12rpx;
  transition: all 0.3s;
}

.mini-tab-active {
  background-color: #ffeaea;
  color: #ee0a24;
  font-weight: 600;
}

/* 记录卡片 */
.record-list {
  padding: 0 24rpx;
}

.record-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.card-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 16rpx;
}

.med-icon-box {
  width: 76rpx;
  height: 76rpx;
  border-radius: 20rpx;
  background-color: #fff0f1;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.card-info {
  flex: 1;
}

.med-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #323233;
  line-height: 1.4;
}

.med-meta {
  margin-top: 4rpx;
}

.card-bottom {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.card-period {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.swipe-delete {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 130rpx;
  height: 100%;
  background-color: #ee0a24;
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 0 20rpx 20rpx 0;
}

.page-loading {
  padding-top: 200rpx;
}

.loading-more {
  text-align: center;
  padding: 32rpx 0;
}

.bottom-safe {
  height: calc(100rpx + constant(safe-area-inset-bottom));
  height: calc(100rpx + env(safe-area-inset-bottom));
}
