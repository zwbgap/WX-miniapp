.checkin-container {
  min-height: 100vh;
  background-color: #f6f6f6;
}

/* 统计卡片 */
.stats-card {
  position: relative;
  margin: 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.stats-card-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #07c160, #06ae56);
  z-index: 0;
}

.stats-card-content {
  position: relative;
  z-index: 1;
  padding: 36rpx 32rpx;
}

.stats-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.2;
}

.stats-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.stats-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: rgba(255, 255, 255, 0.25);
}

.page-loading {
  padding-top: 200rpx;
}

/* 今日打卡列表 */
.checkin-list {
  padding: 16rpx 24rpx;
}

.checkin-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: opacity 0.3s;
}

.checkin-item.item-done {
  opacity: 0.6;
}

.checkin-check {
  margin-right: 24rpx;
}

.check-circle {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 4rpx solid #c8c9cc;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.check-circle-done {
  border-color: #07c160;
  background-color: #07c160;
}

.checkin-info {
  flex: 1;
}

.checkin-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
}

.checkin-meta {
  margin-top: 4rpx;
}

/* 历史记录 */
.history-list {
  padding: 16rpx 24rpx;
}

.history-date-group {
  margin-bottom: 24rpx;
}

.history-date-title {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 0 8rpx 12rpx;
}

.history-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 8rpx;
}

.history-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.dot-done {
  background-color: #07c160;
}

.dot-miss {
  background-color: #ee0a24;
}

.history-info {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.bottom-safe {
  height: calc(40rpx + constant(safe-area-inset-bottom));
  height: calc(40rpx + env(safe-area-inset-bottom));
}
