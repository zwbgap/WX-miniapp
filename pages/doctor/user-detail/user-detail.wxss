.detail-container {
  min-height: 100vh;
  background-color: #f6f6f6;
  padding-bottom: env(safe-area-inset-bottom);
}

.user-header {
  position: relative;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 360rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
}

.header-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 32rpx 40rpx;
}

.back-btn {
  align-self: flex-start;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.15);
  margin-bottom: 24rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  background-color: #e8f5e9;
}

.user-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  margin-top: 20rpx;
}

.user-account {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.content-area {
  position: relative;
  z-index: 1;
  padding: 24rpx 32rpx;
}

.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 20rpx;
}

.menu-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.menu-row:last-child {
  margin-bottom: 0;
}

.menu-item {
  width: calc(50% - 12rpx);
  background: #ffffff;
  padding: 32rpx 20rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #f0f0f0;
}

.menu-item:active {
  transform: scale(0.97);
  background-color: #f9fafb;
}

.danger-item {
  width: 100%;
  border: 2rpx solid #fee2e2;
  background: linear-gradient(135deg, #fff5f5 0%, #ffffff 100%);
}

.menu-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-bottom: 12rpx;
}

.green-icon {
  background-color: #dcfce7;
}

.purple-icon {
  background-color: #ede9fe;
}

.orange-icon {
  background-color: #ffedd5;
}

.red-icon {
  background-color: #fee2e2;
}

.danger-icon {
  background-color: #fee2e2;
}

.menu-text {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.menu-desc {
  font-size: 22rpx;
  color: #969799;
  text-align: center;
}

.danger-item .menu-text {
  color: #dc2626;
}