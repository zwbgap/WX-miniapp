.users-container {
  min-height: 100vh;
  background-color: #f6f6f6;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.users-list {
  padding: 0 24rpx;
}

.user-card {
  background: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx 24rpx 16rpx;
}

.card-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 3rpx solid #f0f0f0;
  background-color: #e8f5e9;
  flex-shrink: 0;
}

.card-user-info {
  flex: 1;
  margin-left: 20rpx;
}

.card-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 4rpx;
}

.card-account {
  font-size: 24rpx;
  color: #969799;
}

.card-health {
  margin: 0 24rpx 16rpx;
  padding: 20rpx 20rpx 4rpx;
  background-color: #fafbfc;
  border-radius: 16rpx;
  border: 1rpx solid #f0f0f0;
}

.health-title {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.health-title text {
  font-size: 26rpx;
  font-weight: 600;
  color: #323233;
}

.card-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background-color: #1989fa;
  margin-right: 10rpx;
}

.health-body {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.health-item {
  width: 50%;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 14rpx 0;
}

.health-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.health-info {
  display: flex;
  flex-direction: column;
}

.health-label {
  font-size: 22rpx;
  color: #969799;
}

.health-value {
  font-size: 26rpx;
  color: #323233;
  font-weight: 500;
  margin-top: 2rpx;
}

.health-value.warn {
  color: #ff976a;
}

.health-warn-section {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #ffedd5;
}

.warn-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #ee0a24;
  margin-bottom: 12rpx;
}

.warn-list {
  display: flex;
  flex-direction: column;
}

.warn-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
}

.warn-item + .warn-item {
  border-top: 1rpx solid #fff1f0;
}

.warn-label {
  font-size: 24rpx;
  color: #969799;
}

.warn-value {
  font-size: 24rpx;
  color: #ff976a;
  font-weight: 500;
  max-width: 60%;
  text-align: right;
  word-break: break-all;
}

.warn-value.danger {
  color: #ee0a24;
}

.card-footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #f5f5f5;
  background-color: #fafafa;
}

.footer-link {
  font-size: 24rpx;
  color: #1989fa;
  font-weight: 500;
  margin-right: 6rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #646566;
  font-weight: 500;
}

.empty-hint {
  font-size: 24rpx;
  color: #969799;
  margin-top: 8rpx;
}