.exam-container {
  min-height: 100vh;
  background-color: #f6f6f6;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.page-header {
  padding: 32rpx 32rpx 16rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.header-desc {
  font-size: 26rpx;
  color: #969799;
  margin-top: 8rpx;
}

.section {
  margin: 16rpx 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  padding: 16rpx 32rpx 16rpx;
}

.user-grid {
  padding: 0 24rpx;
}

.user-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #f0f0f0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
  transition: all 0.2s ease;
}

.user-card.selected {
  border-color: #07c160;
  background-color: #f6fef9;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid #f0f0f0;
  background-color: #e8f5e9;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  margin-left: 20rpx;
}

.user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
}

.user-account {
  font-size: 24rpx;
  color: #969799;
  margin-top: 4rpx;
  display: block;
}

.select-indicator {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #d9d9d9;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.select-indicator.checked {
  background-color: #07c160;
  border-color: #07c160;
}

.form-card {
  background: #ffffff;
  border-radius: 20rpx;
  margin: 0 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
}

.action-row {
  padding: 32rpx 32rpx;
}

.content-section {
  background: #ffffff;
  border-radius: 20rpx;
  margin: 24rpx 24rpx 0;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
}

.content-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.content-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.content-counter {
  font-size: 22rpx;
  color: #c8c9cc;
}

.content-textarea {
  width: 100%;
  min-height: 280rpx;
  padding: 16rpx;
  background-color: #fafbfc;
  border-radius: 12rpx;
  border: 1rpx solid #f0f0f0;
  font-size: 28rpx;
  color: #323233;
  line-height: 1.6;
  box-sizing: border-box;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #646566;
  font-weight: 500;
}

.empty-hint {
  font-size: 24rpx;
  color: #969799;
  margin-top: 8rpx;
}

.reports-list {
  padding: 24rpx 24rpx 0;
}

.report-card {
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}

.report-card:active {
  background-color: #f9fafb;
}

.report-card-head {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.report-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.report-info {
  flex: 1;
}

.report-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  margin-bottom: 4rpx;
}

.report-user {
  font-size: 24rpx;
  color: #969799;
}

.report-card-body {
  padding: 16rpx 0;
}

.report-card-body text {
  font-size: 24rpx;
  color: #646566;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.report-card-foot {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding-top: 12rpx;
  border-top: 1rpx solid #f5f5f5;
}

.report-card-foot text {
  font-size: 22rpx;
  color: #c8c9cc;
}