<view class="records-container">
  <view class="search-bar">
    <van-search
      value="{{keyword}}"
      placeholder="搜索药物名称"
      show-action
      bind:search="onSearch"
      bind:change="onKeywordChange"
    />
  </view>

  <view class="records-list">
    <van-cell-group inset wx:if="{{records.length > 0}}">
      <van-cell
        wx:for="{{records}}"
        wx:key="_id"
        title="{{item.name || '未填写'}}"
        value="{{item.dosage || '-'}}"
        right-icon="arrow-right"
        bind:tap="onRecordDetail"
        data-id="{{item._id}}"
      >
        <template slot="icon">
          <view class="record-avatar">💊</view>
        </template>
      </van-cell>
    </van-cell-group>

    <view class="empty-state" wx:else>
      <text class="empty-icon">💊</text>
      <text class="empty-text">暂无用药记录</text>
    </view>
  </view>
</view>