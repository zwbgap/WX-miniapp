.profile-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.page-loading {
  padding-top: 300rpx;
}

.profile-header {
  position: relative;
  height: 320rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #07c160 0%, #06b6d4 100%);
  border-radius: 0 0 48rpx 48rpx;
}

.header-content {
  position: relative;
  padding: 60rpx 32rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1;
}

.doctor-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(255,255,255,0.3) 0%, rgba(255,255,255,0.1) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin-bottom: 20rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
}

.doctor-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.doctor-badge {
  background-color: rgba(255, 255, 255, 0.25);
  color: #ffffff;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  backdrop-filter: blur(10px);
}

.form-section {
  padding: 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

.required-hint {
  font-size: 24rpx;
  color: #969799;
  font-weight: normal;
}

.optional-hint {
  font-size: 24rpx;
  color: #969799;
  font-weight: normal;
}

.form-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.form-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.form-row:last-child {
  margin-bottom: 0;
}

.form-row.single {
  display: block;
}

.form-item {
  flex: 1;
}

.form-item.full {
  width: 100%;
}

.form-label {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.required-star {
  color: #ee0a24;
  font-size: 28rpx;
  margin-right: 4rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background-color: #f7f8fa;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.form-input::placeholder {
  color: #c8c9cc;
}

.action-section {
  padding: 32rpx;
  padding-bottom: 60rpx;
}

.bottom-safe {
  height: constant(safe-area-inset-bottom);
  height: env(safe-area-inset-bottom);
}
